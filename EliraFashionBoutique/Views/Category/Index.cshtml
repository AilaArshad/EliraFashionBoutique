        document.getElementById('size-form').reset();
        document.getElementById('size-submit').textContent = 'Save Size';
        setError('size-name-error', false); setInputError('size-name', false);
    }

    async function saveSize(event) {
        event.preventDefault();
        const id   = parseInt(document.getElementById('size-id').value) || 0;
        const name = document.getElementById('size-name').value.trim();

        if (!name) { setError('size-name-error', true); setInputError('size-name', true); return; }
        setError('size-name-error', false); setInputError('size-name', false);

        const btn = document.getElementById('size-submit');
        btn.disabled = true;
        const result = await apiCall('/Size/Save', 'POST', { sizeId: id, sizeName: name });
        btn.disabled = false;

        if (result.success) {
            showToast(id === 0 ? 'Size registered successfully!' : 'Size updated successfully!');
            clearSizeForm();
            await loadAllData();
        } else {
            showToast(result.message || 'Save failed.', 'error');
        }
    }

    function deleteSize(id) {
        triggerDeleteConfirmation('Are you sure you want to delete this Size?', async () => {
            const result = await apiCall(`/Size/Delete/${id}`, 'POST');
            if (result.success) { showToast('Size deleted successfully!'); clearSizeForm(); await loadAllData(); }
            else showToast(result.message || 'Delete failed.', 'error');
        });
    }
</script>
