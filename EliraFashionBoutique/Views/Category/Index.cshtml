@{
    ViewData["Title"] = "Category Catalog Terminal";
    Layout = "_Layout";
}

@section Styles {
<style>
    /* Section heading strip */
    .section-heading {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.07em;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 10px;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* Registry form input field */
    .input-field {
        width: 100%;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 0.85rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        font-family: inherit;
        color: var(--text-dark);
    }
    .input-field:focus {
        border-color: #94a3b8;
        box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
    }
    .input-field:disabled {
        background-color: var(--body-bg);
        color: var(--text-muted);
        cursor: not-allowed;
    }
    .input-field.is-error { border-color: var(--danger); }

    /* Registry table */
    .registry-table th {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        background-color: var(--body-bg);
        padding: 10px 14px;
        border-bottom: 1px solid var(--border-color);
        white-space: nowrap;
    }
    .registry-table td {
        font-size: 0.83rem;
        color: var(--text-body);
        padding: 10px 14px;
        border-bottom: 1px solid var(--border-light);
        white-space: nowrap;
        vertical-align: middle;
    }
    .registry-table tbody tr:last-child td { border-bottom: none; }
    .registry-table tbody tr:hover td { background: #f8fafc; }

    .btn-registry {
        background-color: var(--elira-navy);
        color: #fff;
        font-size: 0.8rem;
        font-weight: 600;
        border: none;
        border-radius: 6px;
        padding: 9px 14px;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
    }
    .btn-registry:hover { background-color: var(--elira-navy-dark); transform: translateY(-1px); }
    .btn-registry:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

    .err-msg { color: var(--danger); font-size: 0.72rem; display: none; margin-top: 4px; font-weight: 500; }
    .err-msg.visible { display: block; }

    /* Color preview box */
    #color-preview {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        border: 1px solid var(--border-color);
        background: #fff;
        flex-shrink: 0;
        transition: background-color 0.2s;
    }

    /* Status badge small */
    .badge-active   { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; font-size:0.7rem; padding: 2px 8px; border-radius: 20px; font-weight:600; }
    .badge-inactive { background: #f1f5f9; color: #475569; border: 1px solid #cbd5e1; font-size:0.7rem; padding: 2px 8px; border-radius: 20px; font-weight:600; }

    /* Scrollable small table */
    .mini-table-wrap { max-height: 230px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 8px; }
</style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">Category Catalog Terminal</h1>
        <p class="page-subtitle">Relational workspace to view and manage catalog hierarchy data live.</p>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     1. BASE CATEGORY REGISTRY
════════════════════════════════════════════════════════ -->
<div class="content-card fade-in-up mb-4">
    <div class="card-title-bar section-heading m-0" style="border-radius: 10px 10px 0 0; border-bottom: 1px solid var(--border-color);">
        <i class="fa-solid fa-folder text-warning"></i> 1. Base Category Registry
    </div>
    <div class="card-body">
        <div class="row g-4">
            <!-- Form -->
            <div class="col-12 col-lg-4">
                <form id="category-form" onsubmit="saveCategory(event)" class="d-flex flex-column gap-3">
                    <input type="hidden" id="category-id" value="0">
                    <div>
                        <label class="form-label small fw-semibold">Category Name</label>
                        <input type="text" id="category-name" placeholder="e.g., Unstitched Fabric" class="input-field">
                        <div class="err-msg" id="category-name-error">Category Name is required.</div>
                    </div>
                    <div>
                        <label class="form-label small fw-semibold">Description</label>
                        <textarea id="category-desc" rows="2" placeholder="Structural notes..." class="input-field" style="resize:none;"></textarea>
                    </div>
                    <button type="submit" id="category-submit" class="btn-registry">
                        <i class="fa-solid fa-plus-circle"></i>
                        <span>Save Category</span>
                    </button>
                </form>
            </div>
            <!-- Table -->
            <div class="col-12 col-lg-8">
                <div class="mini-table-wrap">
                    <table class="table registry-table m-0" id="category-table">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Category Name</th>
                                <th>Description</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     2. SUB-CATEGORY MATRIX
════════════════════════════════════════════════════════ -->
<div class="content-card mb-4">
    <div class="card-title-bar section-heading m-0" style="border-radius: 10px 10px 0 0; border-bottom: 1px solid var(--border-color);">
        <i class="fa-solid fa-sitemap text-info"></i> 2. Sub-Category Matrix
    </div>
    <div class="card-body">
        <div class="row g-4">
            <!-- Form -->
            <div class="col-12 col-lg-4">
                <form id="subcategory-form" onsubmit="saveSubCategory(event)" class="d-flex flex-column gap-3">
                    <input type="hidden" id="subcategory-id" value="0">
                    <div>
                        <label class="form-label small fw-semibold">Parent Category</label>
                        <select id="subcategory-parent" class="input-field" style="background-color: var(--body-bg);">
                            <option value="">Select Parent</option>
                        </select>
                        <div class="err-msg" id="subcategory-parent-error">Parent is required.</div>
                    </div>
                    <div>
                        <label class="form-label small fw-semibold">Sub-Category Name</label>
                        <input type="text" id="subcategory-name" placeholder="e.g., Lawn" class="input-field">
                        <div class="err-msg" id="subcategory-name-error">Sub-Category Name is required.</div>
                    </div>
                    <div class="row g-2">
                        <div class="col-4">
                            <label class="form-label small fw-semibold" style="font-size:0.72rem;">Season</label>
                            <input type="text" id="subcategory-season" placeholder="Summer" class="input-field">
                            <div class="err-msg" id="subcategory-season-error">Required</div>
                        </div>
                        <div class="col-4">
                            <label class="form-label small fw-semibold" style="font-size:0.72rem;">Start Date</label>
                            <input type="date" id="subcategory-start" class="input-field">
                        </div>
                        <div class="col-4">
                            <label class="form-label small fw-semibold" style="font-size:0.72rem;">End Date</label>
                            <input type="date" id="subcategory-end" class="input-field">
                        </div>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="subcategory-active" checked>
                        <label class="form-check-label small fw-semibold" for="subcategory-active">IsActive</label>
                    </div>
                    <button type="submit" id="subcategory-submit" class="btn-registry">
                        <i class="fa-solid fa-link"></i>
                        <span>Save Sub-Category</span>
                    </button>
                </form>
            </div>
            <!-- Table -->
            <div class="col-12 col-lg-8">
                <div class="mini-table-wrap">
                    <table class="table registry-table m-0" id="subcategory-table">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Sub-Category</th>
                                <th>Parent</th>
                                <th>Season</th>
                                <th>Timeline</th>
                                <th>Status</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     3. PROMOTION RULE MATRIX
════════════════════════════════════════════════════════ -->
<div class="content-card mb-4">
    <div class="card-title-bar section-heading m-0" style="border-radius: 10px 10px 0 0; border-bottom: 1px solid var(--border-color);">
        <i class="fa-solid fa-percentage" style="color: var(--success);"></i> 3. Promotion Rule Matrix
    </div>
    <div class="card-body">
        <div class="row g-4">
            <!-- Form -->
            <div class="col-12 col-lg-4">
                <form id="promotion-form" onsubmit="savePromotion(event)" class="d-flex flex-column gap-3">
                    <input type="hidden" id="promotion-id" value="0">
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label small fw-semibold">Target Sub-Category</label>
                            <select id="promotion-sub" class="input-field" style="background-color: var(--body-bg);">
                                <option value="">Select Target Sub</option>
                            </select>
                            <div class="err-msg" id="promotion-sub-error">Target sub is required.</div>
                        </div>
                        <div class="col-5">
                            <label class="form-label small fw-semibold">Discount Metric</label>
                            <input type="text" id="promotion-discount" placeholder="15% OFF" class="input-field">
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label small fw-semibold">Promotion Name</label>
                            <input type="text" id="promotion-name" placeholder="Clearance Pack" class="input-field">
                            <div class="err-msg" id="promotion-name-error">Name is required.</div>
                        </div>
                        <div class="col-5">
                            <label class="form-label small fw-semibold">Promo Type</label>
                            <input type="text" id="promotion-type" placeholder="Seasonal" class="input-field">
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label small fw-semibold" style="font-size:0.72rem;">Start Date</label>
                            <input type="date" id="promotion-start" class="input-field">
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold" style="font-size:0.72rem;">End Date</label>
                            <input type="date" id="promotion-end" class="input-field">
                        </div>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="promotion-active" checked>
                        <label class="form-check-label small fw-semibold" for="promotion-active">IsActive</label>
                    </div>
                    <button type="submit" id="promotion-submit" class="btn-registry">
                        <i class="fa-solid fa-bolt"></i>
                        <span>Save Promotion Rule</span>
                    </button>
                </form>
            </div>
            <!-- Table -->
            <div class="col-12 col-lg-8">
                <div class="mini-table-wrap">
                    <table class="table registry-table m-0" id="promotion-table">
                        <thead>
                            <tr>
                                <th>Target Sub</th>
                                <th>Promo Name</th>
                                <th>Type / Metric</th>
                                <th>Duration</th>
                                <th>Status</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     4. COLOR & SIZE VARIANT REGISTRIES
════════════════════════════════════════════════════════ -->
<div class="row g-4 mb-2">
    <!-- 4a. Color Registry -->
    <div class="col-12 col-xl-6">
        <div class="content-card h-100">
            <div class="card-title-bar section-heading m-0" style="border-radius: 10px 10px 0 0; border-bottom: 1px solid var(--border-color);">
                <i class="fa-solid fa-palette" style="color:#a855f7;"></i> 4a. Color Variant Registry
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12 col-md-5">
                        <form id="color-form" onsubmit="saveColor(event)" class="d-flex flex-column gap-3">
                            <input type="hidden" id="color-id" value="0">
                            <div>
                                <label class="form-label small fw-semibold">Color Name</label>
                                <input type="text" id="color-name" placeholder="Blue" class="input-field">
                                <div class="err-msg" id="color-name-error">Color Name is required.</div>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Hex Code</label>
                                <div class="d-flex gap-2">
                                    <input type="text" id="color-hex" placeholder="#0000FF" class="input-field" oninput="updateColorPreview(this.value)">
                                    <div id="color-preview"></div>
                                </div>
                            </div>
                            <button type="submit" id="color-submit" class="btn-registry">Save Color</button>
                        </form>
                    </div>
                    <div class="col-12 col-md-7">
                        <div class="mini-table-wrap">
                            <table class="table registry-table m-0" id="color-table">
                                <thead>
                                    <tr>
                                        <th>Code</th>
                                        <th>Color Name</th>
                                        <th>Hex Spec</th>
                                        <th class="text-end pe-2">Action</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 4b. Size Registry -->
    <div class="col-12 col-xl-6">
        <div class="content-card h-100">
            <div class="card-title-bar section-heading m-0" style="border-radius: 10px 10px 0 0; border-bottom: 1px solid var(--border-color);">
                <i class="fa-solid fa-ruler-combined" style="color:#6366f1;"></i> 4b. Size Variant Registry
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12 col-md-5">
                        <form id="size-form" onsubmit="saveSize(event)" class="d-flex flex-column gap-3">
                            <input type="hidden" id="size-id" value="0">
                            <div>
                                <label class="form-label small fw-semibold">Size Name</label>
                                <input type="text" id="size-name" placeholder="M" class="input-field">
                                <div class="err-msg" id="size-name-error">Size Name is required.</div>
                            </div>
                            <button type="submit" id="size-submit" class="btn-registry mt-auto">Save Size</button>
                        </form>
                    </div>
                    <div class="col-12 col-md-7">
                        <div class="mini-table-wrap">
                            <table class="table registry-table m-0" id="size-table">
                                <thead>
                                    <tr>
                                        <th>Code</th>
                                        <th>Size Code</th>
                                        <th class="text-end pe-2">Action</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ── Bootstrap Delete Confirm Modal ── -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-3">
                <h5 class="modal-title fw-bold d-flex align-items-center gap-2">
                    <i class="fa-solid fa-triangle-exclamation text-danger"></i> Confirm Deletion
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="confirm-message" class="text-muted mb-0" style="font-size:0.88rem;">
                    Are you sure you want to delete this record? This action cannot be undone.
                </p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-outline-secondary btn-sm px-3" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger btn-sm px-3" id="confirm-ok-btn">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ─── State ────────────────────────────────────────────────
    let categories   = [];
    let subcategories = [];
    let promotions   = [];
    let colors       = [];
    let sizes        = [];

    let activeDeleteCallback = null;
    const bsConfirmModal = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));

    document.addEventListener('DOMContentLoaded', () => {
        loadAllData();
        document.getElementById('confirm-ok-btn').addEventListener('click', () => {
            bsConfirmModal.hide();
            if (activeDeleteCallback) { activeDeleteCallback(); activeDeleteCallback = null; }
        });
    });

    // ─── API helper ───────────────────────────────────────────
    async function apiCall(url, method = 'GET', body = null) {
        const options = { method, headers: { 'Content-Type': 'application/json' } };
        if (body) options.body = JSON.stringify(body);
        try {
            const response = await fetch(url, options);
            if (!response.ok) throw new Error(`API failed: ${response.statusText}`);
            return await response.json();
        } catch (err) {
            console.error(err);
            showToast(err.message, 'error');
            return { success: false, message: err.message };
        }
    }

    // ─── Confirm Delete dialog ────────────────────────────────
    function triggerDeleteConfirmation(message, onConfirm) {
        document.getElementById('confirm-message').textContent = message;
        activeDeleteCallback = onConfirm;
        bsConfirmModal.show();
    }

    // ─── Color preview ────────────────────────────────────────
    function updateColorPreview(val) {
        const preview = document.getElementById('color-preview');
        preview.style.backgroundColor = (val && /^#[0-9A-F]{6}$/i.test(val)) ? val : '#ffffff';
    }

    // ─── Load all data ────────────────────────────────────────
    async function loadAllData() {
        try {
            const [cats, subs, proms, cols, szs] = await Promise.all([
                fetch('/Category/List').then(r => r.json()),
                fetch('/SubCategory/List').then(r => r.json()),
                fetch('/Promotion/List').then(r => r.json()),
                fetch('/Color/List').then(r => r.json()),
                fetch('/Size/List').then(r => r.json())
            ]);
            categories    = cats;
            subcategories = subs;
            promotions    = proms;
            colors        = cols;
            sizes         = szs;

            renderCategories();
            renderSubCategories();
            renderPromotions();
            renderColors();
            renderSizes();
            populateCategoryDropdowns();
            populateSubCategoryDropdowns();
        } catch (err) {
            showToast('Error loading catalogs: ' + err.message, 'error');
        }
    }

    function populateCategoryDropdowns() {
        const dd = document.getElementById('subcategory-parent');
        const selected = dd.value;
        dd.innerHTML = '<option value="">Select Parent</option>';
        categories.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c.categoryId;
            opt.textContent = c.categoryName;
            dd.appendChild(opt);
        });
        dd.value = selected;
    }

    function populateSubCategoryDropdowns() {
        const dd = document.getElementById('promotion-sub');
        const selected = dd.value;
        dd.innerHTML = '<option value="">Select Target Sub</option>';
        subcategories.forEach(s => {
            if (s.isActive) {
                const opt = document.createElement('option');
                opt.value = s.subCategoryId;
                opt.textContent = s.subcategoryName;
                dd.appendChild(opt);
            }
        });
        dd.value = selected;
    }

    // ─── Error helpers ────────────────────────────────────────
    function setError(id, visible) {
        const el = document.getElementById(id);
        if (el) { visible ? el.classList.add('visible') : el.classList.remove('visible'); }
    }
    function setInputError(id, hasError) {
        const el = document.getElementById(id);
        if (el) { hasError ? el.classList.add('is-error') : el.classList.remove('is-error'); }
    }

    // ════════════════════════════════════════════════════
    // 1. CATEGORY
    // ════════════════════════════════════════════════════
    function renderCategories() {
        const tbody = document.querySelector('#category-table tbody');
        tbody.innerHTML = '';
        categories.forEach(c => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="fw-semibold text-muted">#${c.categoryId}</td>
                <td class="fw-medium text-dark">${c.categoryName}</td>
                <td class="truncate text-muted" title="${c.description || ''}">${c.description || 'N/A'}</td>
                <td class="text-end pe-3">
                    <button onclick="editCategory(${c.categoryId})" class="btn btn-sm btn-action me-1">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </button>
                    <button onclick="deleteCategory(${c.categoryId})" class="btn btn-sm btn-action btn-action-danger">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                </td>`;
            tbody.appendChild(tr);
        });
    }

    function editCategory(id) {
        const c = categories.find(x => x.categoryId === id);
        if (!c) return;
        document.getElementById('category-id').value = c.categoryId;
        document.getElementById('category-name').value = c.categoryName;
        document.getElementById('category-desc').value = c.description || '';
        const btn = document.getElementById('category-submit');
        btn.querySelector('span').textContent = 'Update Category';
        btn.querySelector('i').className = 'fa-solid fa-check-circle';
        clearCategoryErrors();
    }

    function clearCategoryErrors() {
        setError('category-name-error', false);
        setInputError('category-name', false);
    }

    function clearCategoryForm() {
        document.getElementById('category-id').value = '0';
        document.getElementById('category-form').reset();
        const btn = document.getElementById('category-submit');
        btn.querySelector('span').textContent = 'Save Category';
        btn.querySelector('i').className = 'fa-solid fa-plus-circle';
        clearCategoryErrors();
    }

    async function saveCategory(event) {
        event.preventDefault();
        const id   = parseInt(document.getElementById('category-id').value) || 0;
        const name = document.getElementById('category-name').value.trim();
        const desc = document.getElementById('category-desc').value.trim();

        if (!name) {
            setError('category-name-error', true);
            setInputError('category-name', true);
            return;
        }
        clearCategoryErrors();

        const btn = document.getElementById('category-submit');
        btn.disabled = true;
        const result = await apiCall('/Category/Save', 'POST', { categoryId: id, categoryName: name, description: desc });
        btn.disabled = false;

        if (result.success) {
            showToast(id === 0 ? 'Category created successfully!' : 'Category updated successfully!');
            clearCategoryForm();
            await loadAllData();
        } else {
            showToast(result.message || 'Save failed.', 'error');
        }
    }

    function deleteCategory(id) {
        triggerDeleteConfirmation('Are you sure you want to delete this Category? All linked Sub-Categories and Promotions will be permanently removed.', async () => {
            const result = await apiCall(`/Category/Delete/${id}`, 'POST');
            if (result.success) {
                showToast('Category deleted successfully!');
                clearCategoryForm();
                await loadAllData();
            } else {
                showToast(result.message || 'Delete failed.', 'error');
            }
        });
    }

    // ════════════════════════════════════════════════════
    // 2. SUB-CATEGORY
    // ════════════════════════════════════════════════════
    function renderSubCategories() {
        const tbody = document.querySelector('#subcategory-table tbody');
        tbody.innerHTML = '';
        subcategories.forEach(s => {
            const start  = s.startDate ? s.startDate.split('T')[0] : 'N/A';
            const end    = s.endDate   ? s.endDate.split('T')[0]   : 'N/A';
            const badge  = s.isActive
                ? '<span class="badge-active">Active</span>'
                : '<span class="badge-inactive">Inactive</span>';
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="fw-semibold text-muted">#${s.subCategoryId}</td>
                <td class="fw-medium text-dark">${s.subcategoryName}</td>
                <td class="text-muted">${s.categoryName}</td>
                <td class="text-muted">${s.seasonType || 'N/A'}</td>
                <td class="text-muted" style="font-size:0.78rem;">${start} → ${end}</td>
                <td>${badge}</td>
                <td class="text-end pe-3">
                    <button onclick="editSubCategory(${s.subCategoryId})" class="btn btn-sm btn-action me-1">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </button>
                    <button onclick="deleteSubCategory(${s.subCategoryId})" class="btn btn-sm btn-action btn-action-danger">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                </td>`;
            tbody.appendChild(tr);
        });
    }

    function editSubCategory(id) {
        const s = subcategories.find(x => x.subCategoryId === id);
        if (!s) return;
        document.getElementById('subcategory-id').value     = s.subCategoryId;
        document.getElementById('subcategory-parent').value = s.categoryId || '';
        document.getElementById('subcategory-name').value   = s.subcategoryName;
        document.getElementById('subcategory-season').value = s.seasonType;
        document.getElementById('subcategory-start').value  = s.startDate ? s.startDate.split('T')[0] : '';
        document.getElementById('subcategory-end').value    = s.endDate   ? s.endDate.split('T')[0]   : '';
        document.getElementById('subcategory-active').checked = s.isActive !== false;
        const btn = document.getElementById('subcategory-submit');
        btn.querySelector('span').textContent = 'Update Sub-Category';
        btn.querySelector('i').className = 'fa-solid fa-check-circle';
        clearSubCategoryErrors();
    }

    function clearSubCategoryErrors() {
        ['subcategory-parent-error','subcategory-name-error','subcategory-season-error'].forEach(id => setError(id, false));
        ['subcategory-parent','subcategory-name','subcategory-season'].forEach(id => setInputError(id, false));
    }

    function clearSubCategoryForm() {
        document.getElementById('subcategory-id').value = '0';
        document.getElementById('subcategory-form').reset();
        document.getElementById('subcategory-active').checked = true;
        const btn = document.getElementById('subcategory-submit');
        btn.querySelector('span').textContent = 'Save Sub-Category';
        btn.querySelector('i').className = 'fa-solid fa-link';
        clearSubCategoryErrors();
    }

    async function saveSubCategory(event) {
        event.preventDefault();
        const id       = parseInt(document.getElementById('subcategory-id').value) || 0;
        const parentId = parseInt(document.getElementById('subcategory-parent').value) || 0;
        const name     = document.getElementById('subcategory-name').value.trim();
        const season   = document.getElementById('subcategory-season').value.trim();

        let hasError = false;
        if (parentId <= 0) { setError('subcategory-parent-error', true); setInputError('subcategory-parent', true); hasError = true; }
        else               { setError('subcategory-parent-error', false); setInputError('subcategory-parent', false); }
        if (!name)         { setError('subcategory-name-error', true);   setInputError('subcategory-name', true);   hasError = true; }
        else               { setError('subcategory-name-error', false);   setInputError('subcategory-name', false); }
        if (!season)       { setError('subcategory-season-error', true); setInputError('subcategory-season', true); hasError = true; }
        else               { setError('subcategory-season-error', false); setInputError('subcategory-season', false); }

        if (hasError) return;

        const btn = document.getElementById('subcategory-submit');
        btn.disabled = true;
        const result = await apiCall('/SubCategory/Save', 'POST', {
            subCategoryId: id, categoryId: parentId, subcategoryName: name, seasonType: season,
            startDate: document.getElementById('subcategory-start').value || null,
            endDate:   document.getElementById('subcategory-end').value   || null,
            isActive:  document.getElementById('subcategory-active').checked
        });
        btn.disabled = false;

        if (result.success) {
            showToast(id === 0 ? 'Sub-Category created successfully!' : 'Sub-Category updated successfully!');
            clearSubCategoryForm();
            await loadAllData();
        } else {
            showToast(result.message || 'Save failed.', 'error');
        }
    }

    function deleteSubCategory(id) {
        triggerDeleteConfirmation('Are you sure you want to delete this Sub-Category? All linked Promotions will be removed.', async () => {
            const result = await apiCall(`/SubCategory/Delete/${id}`, 'POST');
            if (result.success) {
                showToast('Sub-Category deleted successfully!');
                clearSubCategoryForm();
                await loadAllData();
            } else {
                showToast(result.message || 'Delete failed.', 'error');
            }
        });
    }

    // ════════════════════════════════════════════════════
    // 3. PROMOTION
    // ════════════════════════════════════════════════════
    function renderPromotions() {
        const tbody = document.querySelector('#promotion-table tbody');
        tbody.innerHTML = '';
        promotions.forEach(p => {
            const start = p.startDate ? p.startDate.split('T')[0] : 'N/A';
            const end   = p.endDate   ? p.endDate.split('T')[0]   : 'N/A';
            const badge = p.isActive
                ? '<span class="badge-active">Active</span>'
                : '<span class="badge-inactive">Inactive</span>';
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="fw-medium">${p.subcategoryName}</td>
                <td class="fw-medium text-dark">${p.discountName}</td>
                <td><span class="fw-semibold">${p.promotionDiscount || '0%'}</span>
                    <span class="text-muted" style="font-size:0.75rem;"> (${p.discountType || 'General'})</span></td>
                <td class="text-muted" style="font-size:0.78rem;">${start} → ${end}</td>
                <td>${badge}</td>
                <td class="text-end pe-3">
                    <button onclick="editPromotion(${p.promotionId})" class="btn btn-sm btn-action me-1">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </button>
                    <button onclick="deletePromotion(${p.promotionId})" class="btn btn-sm btn-action btn-action-danger">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                </td>`;
            tbody.appendChild(tr);
        });
    }

    function editPromotion(id) {
        const p = promotions.find(x => x.promotionId === id);
        if (!p) return;
        document.getElementById('promotion-id').value       = p.promotionId;
        document.getElementById('promotion-sub').value      = p.subCategoryId || '';
        document.getElementById('promotion-discount').value = p.promotionDiscount || '';
        document.getElementById('promotion-name').value     = p.discountName || '';
        document.getElementById('promotion-type').value     = p.discountType || '';
        document.getElementById('promotion-start').value    = p.startDate ? p.startDate.split('T')[0] : '';
        document.getElementById('promotion-end').value      = p.endDate   ? p.endDate.split('T')[0]   : '';
        document.getElementById('promotion-active').checked = p.isActive !== false;
        const btn = document.getElementById('promotion-submit');
        btn.querySelector('span').textContent = 'Update Promotion';
        btn.querySelector('i').className = 'fa-solid fa-check-circle';
    }

    function clearPromotionForm() {
        document.getElementById('promotion-id').value = '0';
        document.getElementById('promotion-form').reset();
        document.getElementById('promotion-active').checked = true;
        const btn = document.getElementById('promotion-submit');
        btn.querySelector('span').textContent = 'Save Promotion Rule';
        btn.querySelector('i').className = 'fa-solid fa-bolt';
        setError('promotion-sub-error', false);  setInputError('promotion-sub', false);
        setError('promotion-name-error', false); setInputError('promotion-name', false);
    }

    async function savePromotion(event) {
        event.preventDefault();
        const id    = parseInt(document.getElementById('promotion-id').value) || 0;
        const subId = parseInt(document.getElementById('promotion-sub').value) || 0;
        const name  = document.getElementById('promotion-name').value.trim();

        let hasError = false;
        if (subId <= 0) { setError('promotion-sub-error', true);  setInputError('promotion-sub', true);  hasError = true; }
        else            { setError('promotion-sub-error', false); setInputError('promotion-sub', false); }
        if (!name)      { setError('promotion-name-error', true); setInputError('promotion-name', true); hasError = true; }
        else            { setError('promotion-name-error', false); setInputError('promotion-name', false); }
        if (hasError) return;

        const btn = document.getElementById('promotion-submit');
        btn.disabled = true;
        const result = await apiCall('/Promotion/Save', 'POST', {
            promotionId: id, subCategoryId: subId,
            promotionDiscount: document.getElementById('promotion-discount').value.trim(),
            discountName: name,
            discountType: document.getElementById('promotion-type').value.trim(),
            startDate: document.getElementById('promotion-start').value || null,
            endDate:   document.getElementById('promotion-end').value   || null,
            isActive:  document.getElementById('promotion-active').checked
        });
        btn.disabled = false;

        if (result.success) {
            showToast(id === 0 ? 'Promotion created successfully!' : 'Promotion updated successfully!');
            clearPromotionForm();
            await loadAllData();
        } else {
            showToast(result.message || 'Save failed.', 'error');
        }
    }

    function deletePromotion(id) {
        triggerDeleteConfirmation('Are you sure you want to delete this Promotion rule?', async () => {
            const result = await apiCall(`/Promotion/Delete/${id}`, 'POST');
            if (result.success) { showToast('Promotion deleted successfully!'); clearPromotionForm(); await loadAllData(); }
            else showToast(result.message || 'Delete failed.', 'error');
        });
    }

    // ════════════════════════════════════════════════════
    // 4a. COLOR
    // ════════════════════════════════════════════════════
    function renderColors() {
        const tbody = document.querySelector('#color-table tbody');
        tbody.innerHTML = '';
        colors.forEach(c => {
            const hex = c.hexCode && c.hexCode.startsWith('#') ? c.hexCode : '#FFFFFF';
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="fw-semibold text-muted">#${c.colorId}</td>
                <td class="fw-medium d-flex align-items-center gap-2">
                    <span style="width:12px;height:12px;border-radius:50%;background:${hex};border:1px solid #e2e8f0;display:inline-block;"></span>
                    ${c.colorName}
                </td>
                <td class="text-muted font-monospace">${c.hexCode || 'N/A'}</td>
                <td class="text-end pe-2">
                    <button onclick="editColor(${c.colorId})" class="btn btn-sm btn-action me-1"><i class="fa-solid fa-pen-to-square"></i></button>
                    <button onclick="deleteColor(${c.colorId})" class="btn btn-sm btn-action btn-action-danger"><i class="fa-solid fa-trash-can"></i></button>
                </td>`;
            tbody.appendChild(tr);
        });
    }

    function editColor(id) {
        const c = colors.find(x => x.colorId === id);
        if (!c) return;
        document.getElementById('color-id').value   = c.colorId;
        document.getElementById('color-name').value = c.colorName;
        document.getElementById('color-hex').value  = c.hexCode || '';
        updateColorPreview(c.hexCode || '');
        document.getElementById('color-submit').textContent = 'Update Color';
        setError('color-name-error', false); setInputError('color-name', false);
    }

    function clearColorForm() {
        document.getElementById('color-id').value = '0';
        document.getElementById('color-form').reset();
        updateColorPreview('');
        document.getElementById('color-submit').textContent = 'Save Color';
        setError('color-name-error', false); setInputError('color-name', false);
    }

    async function saveColor(event) {
        event.preventDefault();
        const id   = parseInt(document.getElementById('color-id').value) || 0;
        const name = document.getElementById('color-name').value.trim();
        const hex  = document.getElementById('color-hex').value.trim();

        if (!name) { setError('color-name-error', true); setInputError('color-name', true); return; }
        setError('color-name-error', false); setInputError('color-name', false);

        const btn = document.getElementById('color-submit');
        btn.disabled = true;
        const result = await apiCall('/Color/Save', 'POST', { colorId: id, colorName: name, hexCode: hex });
        btn.disabled = false;

        if (result.success) {
            showToast(id === 0 ? 'Color registered successfully!' : 'Color updated successfully!');
            clearColorForm();
            await loadAllData();
        } else {
            showToast(result.message || 'Save failed.', 'error');
        }
    }

    function deleteColor(id) {
        triggerDeleteConfirmation('Are you sure you want to delete this Color?', async () => {
            const result = await apiCall(`/Color/Delete/${id}`, 'POST');
            if (result.success) { showToast('Color deleted successfully!'); clearColorForm(); await loadAllData(); }
            else showToast(result.message || 'Delete failed.', 'error');
        });
    }

    // ════════════════════════════════════════════════════
    // 4b. SIZE
    // ════════════════════════════════════════════════════
    function renderSizes() {
        const tbody = document.querySelector('#size-table tbody');
        tbody.innerHTML = '';
        sizes.forEach(s => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="fw-semibold text-muted">#${s.sizeId}</td>
                <td class="fw-medium">${s.sizeName}</td>
                <td class="text-end pe-2">
                    <button onclick="editSize(${s.sizeId})" class="btn btn-sm btn-action me-1"><i class="fa-solid fa-pen-to-square"></i></button>
                    <button onclick="deleteSize(${s.sizeId})" class="btn btn-sm btn-action btn-action-danger"><i class="fa-solid fa-trash-can"></i></button>
                </td>`;
            tbody.appendChild(tr);
        });
    }

    function editSize(id) {
        const s = sizes.find(x => x.sizeId === id);
        if (!s) return;
        document.getElementById('size-id').value   = s.sizeId;
        document.getElementById('size-name').value = s.sizeName;
        document.getElementById('size-submit').textContent = 'Update Size';
        setError('size-name-error', false); setInputError('size-name', false);
