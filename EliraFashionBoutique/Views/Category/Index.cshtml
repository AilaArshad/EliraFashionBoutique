@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elira Management - Category Catalog Terminal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background-color: #f8fafc; font-family: 'Inter', sans-serif; }
        
        /* Workspace UI Elements */
        .card { background: white; border-radius: 8px; border: 1px solid #e2e8f0; }
        .input-field { width: 100%; border: 1px solid #cbd5e1; border-radius: 4px; padding: 8px 12px; font-size: 14px; outline: none; transition: all 0.2s; }
        .input-field:focus { border-color: #1e293b; ring: 1px; ring-color: #1e293b; }
        .input-field:disabled { background-color: #f1f5f9; color: #64748b; cursor: not-allowed; border-color: #cbd5e1; }
        .btn-workspace { background-color: #1e293b; color: white; font-size: 13px; font-weight: 500; transition: all 0.2s; }
        .btn-workspace:hover { background-color: #0f172a; }
        .section-heading { font-size: 12px; font-weight: 700; color: #475569; text-transform: uppercase; tracking-wider: 0.05em; border-bottom: 1px solid #e2e8f0; padding-bottom: 8px; margin-bottom: 16px; }
        
        /* Table Styles with structural spacing */
        th { font-size: 11px; font-weight: 700; color: #64748b; text-transform: uppercase; padding: 12px; background-color: #f8fafc; border-bottom: 1px solid #e2e8f0; white-space: nowrap; }
        td { font-size: 13px; color: #334155; padding: 12px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; white-space: nowrap; }
        .truncate-text { max-width: 140px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* Custom Animations */
        .toast-enter { transform: translateY(-1rem); opacity: 0; }
        .toast-show { transform: translateY(0); opacity: 1; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
    </style>
</head>
<body class="min-h-screen relative">

    <!-- Toast Notifications Container -->
    <div id="toast-container" class="fixed top-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"></div>

    <!-- Custom Premium Confirm Delete Modal -->
    <div id="confirm-modal" class="fixed inset-0 z-50 hidden bg-slate-900/40 backdrop-blur-sm flex items-center justify-center">
        <div class="bg-white rounded-lg p-6 max-w-sm w-full mx-4 shadow-xl border border-slate-100 transform scale-95 transition-all">
            <div class="flex items-center gap-3 mb-3 text-rose-600">
                <i class="fas fa-exclamation-triangle text-xl"></i>
                <h3 class="text-lg font-bold text-slate-900">Confirm Deletion</h3>
            </div>
            <p id="confirm-message" class="text-slate-500 text-sm mb-6">Are you sure you want to delete this record? This action cannot be undone.</p>
            <div class="flex justify-end gap-3">
                <button id="confirm-cancel" class="px-4 py-2 text-xs font-semibold text-slate-500 hover:text-slate-800 border border-slate-200 rounded">Cancel</button>
                <button id="confirm-ok" class="px-4 py-2 text-xs font-semibold text-white bg-rose-600 hover:bg-rose-700 rounded">Delete</button>
            </div>
        </div>
    </div>

    <main class="p-4 sm:p-6 lg:p-8 w-full overflow-hidden mx-auto max-w-7xl">
        
        <header class="mb-6 lg:mb-8 flex justify-between items-center">
            <div>
                <h1 class="text-xl sm:text-2xl font-bold text-slate-900">Category Catalog Terminal</h1>
                <p class="text-slate-500 text-xs sm:text-sm mt-0.5">Relational workspace to view and manage data entries live.</p>
            </div>
            <div class="flex items-center gap-2">
                <a class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded text-xs font-semibold bg-slate-100 hover:bg-slate-200 text-slate-800 border border-slate-300" href="/Product/Index">
                    <i class="fas fa-box"></i> Product Catalog Studio
                </a>
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-200">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                    Live Connected
                </span>
            </div>
        </header>

        <div class="space-y-6 sm:space-y-8">
            
            <!-- Category Registry -->
            <div class="card p-4 sm:p-6 shadow-sm">
                <div class="section-heading flex items-center">
                    <i class="fas fa-folder text-amber-500 mr-2"></i> 1. Base Category Registry
                </div>
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <form id="category-form" class="space-y-4 lg:border-r lg:border-slate-100 lg:pr-6" onsubmit="saveCategory(event)">
                        <input type="hidden" id="category-id" value="0">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 mb-1">Category Name</label>
                            <input type="text" id="category-name" placeholder="e.g., Unstitched Fabric" class="input-field">
                            <span id="category-name-error" class="text-rose-500 text-[11px] hidden mt-1 block font-medium">Category Name is required.</span>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 mb-1">Description</label>
                            <textarea id="category-desc" rows="2" placeholder="Structural notes..." class="input-field resize-none"></textarea>
                        </div>
                        <button type="submit" id="category-submit" class="w-full btn-workspace py-2.5 rounded font-semibold text-xs uppercase tracking-wider flex items-center justify-center gap-2">
                            <i class="fas fa-plus-circle"></i> <span>Save Category</span>
                        </button>
                    </form>
                    <div class="lg:col-span-2 overflow-x-auto border border-slate-100 rounded-md">
                        <table class="w-full min-w-[500px] text-left border-collapse" id="category-table">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Category Name</th>
                                    <th>Description</th>
                                    <th class="text-right px-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            <!-- Sub-Category Matrix -->
            <div class="card p-4 sm:p-6 shadow-sm">
                <div class="section-heading flex items-center">
                    <i class="fas fa-sitemap text-sky-500 mr-2"></i> 2. Sub-Category Matrix
                </div>
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <form id="subcategory-form" class="space-y-4 lg:border-r lg:border-slate-100 lg:pr-6" onsubmit="saveSubCategory(event)">
                        <input type="hidden" id="subcategory-id" value="0">
                        <div class="grid grid-cols-2 gap-2">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">Parent Category</label>
                                <select id="subcategory-parent" class="input-field bg-slate-50">
                                    <option value="">Select Parent</option>
                                </select>
                                <span id="subcategory-parent-error" class="text-rose-500 text-[11px] hidden mt-1 block font-medium">Parent is required.</span>
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 mb-1">Sub-Category Name</label>
                            <input type="text" id="subcategory-name" placeholder="e.g., Lawn" class="input-field">
                            <span id="subcategory-name-error" class="text-rose-500 text-[11px] hidden mt-1 block font-medium">Sub-Category Name is required.</span>
                        </div>
                        <div class="grid grid-cols-3 gap-2">
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 mb-0.5">Season</label>
                                <input type="text" id="subcategory-season" placeholder="Summer" class="input-field !px-2">
                                <span id="subcategory-season-error" class="text-rose-500 text-[9px] hidden mt-0.5 block font-medium">Required</span>
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 mb-0.5">Start Date</label>
                                <input type="date" id="subcategory-start" class="input-field !px-1 text-xs">
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 mb-0.5">End Date</label>
                                <input type="date" id="subcategory-end" class="input-field !px-1 text-xs">
                            </div>
                        </div>
                        <div>
                            <label class="flex items-center space-x-2 text-xs font-bold text-slate-600 cursor-pointer py-1">
                                <input type="checkbox" id="subcategory-active" checked class="rounded border-slate-300 text-slate-800 focus:ring-slate-500 w-4 h-4">
                                <span>IsActive Status</span>
                            </label>
                        </div>
                        <button type="submit" id="subcategory-submit" class="w-full btn-workspace py-2.5 rounded font-semibold text-xs uppercase tracking-wider flex items-center justify-center gap-2">
                            <i class="fas fa-link"></i> <span>Save Sub-Category</span>
                        </button>
                    </form>
                    <div class="lg:col-span-2 overflow-x-auto border border-slate-100 rounded-md">
                        <table class="w-full min-w-[750px] text-left border-collapse" id="subcategory-table">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Sub-Category Name</th>
                                    <th>Parent Category</th>
                                    <th>Season</th>
                                    <th>Timeline</th>
                                    <th>Status</th>
                                    <th class="text-right px-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Loaded dynamically -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Promotion Registry -->
            <div class="card p-4 sm:p-6 shadow-sm">
                <div class="section-heading flex items-center">
                    <i class="fas fa-percentage text-emerald-500 mr-2"></i> 3. Promotion Rule Matrix
                </div>
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <form id="promotion-form" class="space-y-4 lg:border-r lg:border-slate-100 lg:pr-6" onsubmit="savePromotion(event)">
                        <input type="hidden" id="promotion-id" value="0">
                        <div class="grid grid-cols-2 gap-2">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">Target Sub-Category</label>
                                <select id="promotion-sub" class="input-field bg-slate-50">
                                    <option value="">Select Target Sub</option>
                                </select>
                                <span id="promotion-sub-error" class="text-rose-500 text-[11px] hidden mt-1 block font-medium">Target sub is required.</span>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">Discount Metric</label>
                                <input type="text" id="promotion-discount" placeholder="15% OFF" class="input-field">
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-2">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">Promotion Name</label>
                                <input type="text" id="promotion-name" placeholder="Clearance Pack" class="input-field">
                                <span id="promotion-name-error" class="text-rose-500 text-[11px] hidden mt-1 block font-medium">Name is required.</span>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">Promotion Type</label>
                                <input type="text" id="promotion-type" placeholder="Seasonal" class="input-field">
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-2">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">Start Date</label>
                                <input type="date" id="promotion-start" class="input-field text-xs">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">End Date</label>
                                <input type="date" id="promotion-end" class="input-field text-xs">
                            </div>
                        </div>
                        <div>
                            <label class="flex items-center space-x-2 text-xs font-bold text-slate-600 cursor-pointer py-1">
                                <input type="checkbox" id="promotion-active" checked class="rounded border-slate-300 text-slate-800 focus:ring-slate-500 w-4 h-4">
                                <span>IsActive Status</span>
                            </label>
                        </div>
                        <button type="submit" id="promotion-submit" class="w-full btn-workspace py-2.5 rounded font-semibold text-xs uppercase tracking-wider flex items-center justify-center gap-2">
                            <i class="fas fa-bolt"></i> <span>Save Promotion Rule</span>
                        </button>
                    </form>
                    <div class="lg:col-span-2 overflow-x-auto border border-slate-100 rounded-md">
                        <table class="w-full min-w-[750px] text-left border-collapse" id="promotion-table">
                            <thead>
                                <tr>
                                    <th>Target Sub</th>
                                    <th>Promotion Name</th>
                                    <th>Type / Metric</th>
                                    <th>Duration Timeline</th>
                                    <th>Status</th>
                                    <th class="text-right px-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Loaded dynamically -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Color and Size Dual Column Grid -->
            <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
                <!-- Color Variant Registry -->
                <div class="card p-4 sm:p-6 shadow-sm">
                    <div class="section-heading flex items-center"><i class="fas fa-palette text-purple-500 mr-2"></i> 4a. Color Variant Registry</div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <form id="color-form" class="space-y-3 md:border-r md:border-slate-50 md:pr-4" onsubmit="saveColor(event)">
                            <input type="hidden" id="color-id" value="0">
                            <div>
                                <label class="block text-[11px] font-semibold text-slate-500 mb-0.5">Color Name</label>
                                <input type="text" id="color-name" placeholder="Blue" class="input-field !py-1.5">
                                <span id="color-name-error" class="text-rose-500 text-[10px] hidden mt-0.5 block font-medium">Color Name is required.</span>
                            </div>
                            <div>
                                <label class="block text-[11px] font-semibold text-slate-500 mb-0.5">Hex Code</label>
                                <div class="flex gap-2">
                                    <input type="text" id="color-hex" placeholder="#0000FF" class="input-field !py-1.5 flex-grow" oninput="updateColorPreview(this.value)">
                                    <div id="color-preview" class="w-9 h-9 rounded border border-slate-200 bg-white shadow-sm flex-shrink-0 transition-all"></div>
                                </div>
                            </div>
                            <button type="submit" id="color-submit" class="w-full bg-slate-800 hover:bg-slate-900 text-white py-2 rounded text-xs font-bold uppercase tracking-wider flex items-center justify-center gap-1.5">
                                Save Color
                            </button>
                        </form>
                        <div class="overflow-x-auto border border-slate-100 rounded-md md:border-none md:overflow-y-auto max-h-[220px]">
                            <table class="w-full text-left text-xs min-w-[200px]" id="color-table">
                                <thead>
                                    <tr>
                                        <th>Code</th>
                                        <th>Color Name</th>
                                        <th>Hex Spec</th>
                                        <th class="text-right px-2">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Loaded dynamically -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Size Variant Registry -->
                <div class="card p-4 sm:p-6 shadow-sm">
                    <div class="section-heading flex items-center"><i class="fas fa-ruler-combined text-indigo-500 mr-2"></i> 4b. Size Variant Registry</div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <form id="size-form" class="space-y-3 md:border-r md:border-slate-50 md:pr-4 flex flex-col justify-between" onsubmit="saveSize(event)">
                            <input type="hidden" id="size-id" value="0">
                            <div>                               
                                <div>
                                    <label class="block text-[11px] font-semibold text-slate-500 mb-0.5">Size Name</label>
                                    <input type="text" id="size-name" placeholder="M" class="input-field !py-1.5">
                                    <span id="size-name-error" class="text-rose-500 text-[10px] hidden mt-0.5 block font-medium">Size Name is required.</span>
                                </div>
                            </div>
                            <button type="submit" id="size-submit" class="w-full bg-slate-800 hover:bg-slate-900 text-white py-2 rounded text-xs font-bold uppercase tracking-wider mt-4 flex items-center justify-center gap-1.5">
                                Save Size
                            </button>
                        </form>
                        <div class="overflow-x-auto border border-slate-100 rounded-md md:border-none md:overflow-y-auto max-h-[220px]">
                            <table class="w-full text-left text-xs min-w-[200px]" id="size-table">
                                <thead>
                                    <tr>
                                        <th>Code</th>
                                        <th>Size Code</th>
                                        <th class="text-right px-2">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Loaded dynamically -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Global Application Code -->
    <script>
        // Store current states
        let categories = [];
        let subcategories = [];
        let promotions = [];
        let colors = [];
        let sizes = [];

        // Delete modal confirmation callback tracker
        let activeDeleteCallback = null;

        // Startup lifecycle
        document.addEventListener("DOMContentLoaded", () => {
            loadAllData();
            setupDeleteModal();
        });

        // Fetch wrapper to handle request settings with JSON defaults
        async function apiCall(url, method = "GET", body = null) {
            const options = {
                method: method,
                headers: {
                    "Content-Type": "application/json"
                }
            };
            if (body) {
                options.body = JSON.stringify(body);
            }
            try {
                const response = await fetch(url, options);
                if (!response.ok) {
                    throw new Error(`API failed: ${response.statusText}`);
                }
                return await response.json();
            } catch (err) {
                console.error(err);
                showToast(err.message, "error");
                return { success: false, message: err.message };
            }
        }

        // Load all tables and configurations
        async function loadAllData() {
            try {
                const [cats, subs, proms, cols, szs] = await Promise.all([
                    fetch("/Category/List").then(res => res.json()),
                    fetch("/SubCategory/List").then(res => res.json()),
                    fetch("/Promotion/List").then(res => res.json()),
                    fetch("/Color/List").then(res => res.json()),
                    fetch("/Size/List").then(res => res.json())
                ]);

                categories = cats;
                subcategories = subs;
                promotions = proms;
                colors = cols;
                sizes = szs;

                renderCategories();
                renderSubCategories();
                renderPromotions();
                renderColors();
                renderSizes();

                populateCategoryDropdowns();
                populateSubCategoryDropdowns();
            } catch (err) {
                showToast("Error loading catalogs: " + err.message, "error");
            }
        }

        // Show a premium floating toast notification
        function showToast(message, type = "success") {
            const container = document.getElementById("toast-container");
            const toast = document.createElement("div");
            toast.className = `p-3 rounded-lg shadow-lg text-xs font-semibold flex items-center gap-2 border bg-white pointer-events-auto toast-enter ${
                type === "success" 
                    ? "text-emerald-700 bg-emerald-50 border-emerald-200" 
                    : "text-rose-700 bg-rose-50 border-rose-200"
            }`;
            
            const icon = document.createElement("i");
            icon.className = type === "success" ? "fas fa-check-circle text-emerald-500" : "fas fa-times-circle text-rose-500";
            
            const text = document.createElement("span");
            text.textContent = message;

            toast.appendChild(icon);
            toast.appendChild(text);
            container.appendChild(toast);

            // Trigger animation frame
            requestAnimationFrame(() => {
                toast.classList.add("toast-show");
            });

            // Auto dismiss toast
            setTimeout(() => {
                toast.classList.remove("toast-show");
                toast.style.transform = "translateY(-1rem)";
                toast.style.opacity = "0";
                toast.style.transition = "all 0.3s cubic-bezier(0.16, 1, 0.3, 1)";
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Custom Confirm Delete Dialog handlers
        function setupDeleteModal() {
            const modal = document.getElementById("confirm-modal");
            const btnCancel = document.getElementById("confirm-cancel");
            const btnOk = document.getElementById("confirm-ok");

            btnCancel.addEventListener("click", () => {
                modal.classList.add("hidden");
                activeDeleteCallback = null;
            });

            btnOk.addEventListener("click", () => {
                modal.classList.add("hidden");
                if (activeDeleteCallback) {
                    activeDeleteCallback();
                    activeDeleteCallback = null;
                }
            });
        }

        function triggerDeleteConfirmation(message, onConfirm) {
            document.getElementById("confirm-message").textContent = message;
            document.getElementById("confirm-modal").classList.remove("hidden");
            activeDeleteCallback = onConfirm;
        }

        // Update hex color box preview
        function updateColorPreview(val) {
            const preview = document.getElementById("color-preview");
            if (val && val.match(/^#[0-9A-F]{6}$/i)) {
                preview.style.backgroundColor = val;
            } else {
                preview.style.backgroundColor = "#FFFFFF";
            }
        }

        // Re-populate Parent Category Select Dropdown
        function populateCategoryDropdowns() {
            const dropdown = document.getElementById("subcategory-parent");
            const selectedVal = dropdown.value;
            dropdown.innerHTML = '<option value="">Select Parent</option>';
            categories.forEach(c => {
                const opt = document.createElement("option");
                opt.value = c.categoryId;
                opt.textContent = c.categoryName;
                dropdown.appendChild(opt);
            });
            dropdown.value = selectedVal;
        }

        // Re-populate Target Sub-Category Select Dropdown
        function populateSubCategoryDropdowns() {
            const dropdown = document.getElementById("promotion-sub");
            const selectedVal = dropdown.value;
            dropdown.innerHTML = '<option value="">Select Target Sub</option>';
            subcategories.forEach(s => {
                const opt = document.createElement("option");
                opt.value = s.subCategoryId;
                opt.textContent = s.subcategoryName;
                dropdown.appendChild(opt);
            });
            dropdown.value = selectedVal;
        }

        // 1. RENDER & SAVE CATEGORY
        function renderCategories() {
            const tbody = document.querySelector("#category-table tbody");
            tbody.innerHTML = "";
            categories.forEach(c => {
                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td class="font-semibold text-slate-500">#${c.categoryId}</td>
                    <td class="font-medium text-slate-800">${c.categoryName}</td>
                    <td class="text-slate-500 truncate-text" title="${c.description || ''}">${c.description || 'N/A'}</td>
                    <td class="text-right px-4">
                        <button onclick="editCategory(${c.categoryId})" class="text-slate-600 hover:text-slate-900 font-semibold text-xs mr-3"><i class="fas fa-edit"></i> Edit</button>
                        <button onclick="deleteCategory(${c.categoryId})" class="text-rose-600 hover:text-rose-900 font-semibold text-xs"><i class="fas fa-trash-alt"></i> Delete</button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function editCategory(id) {
            const c = categories.find(item => item.categoryId === id);
            if (!c) return;
            document.getElementById("category-id").value = c.categoryId;
            document.getElementById("category-name").value = c.categoryName;
            document.getElementById("category-desc").value = c.description || "";
            document.getElementById("category-submit").querySelector("span").textContent = "Update Category";
            document.getElementById("category-submit").querySelector("i").className = "fas fa-check-circle";
            
            // Clear errors
            document.getElementById("category-name-error").classList.add("hidden");
            document.getElementById("category-name").classList.remove("border-rose-500");
        }

