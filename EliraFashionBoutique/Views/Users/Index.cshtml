@{
    ViewData["Title"] = "User Management";
    Layout = "_Layout";
}

@section Styles {
<style>
    .badge-role-admin    { background-color: #dc3545 !important; color:#fff; }
    .badge-role-customer { background-color: var(--elira-navy) !important; color:#fff; }
    .badge-role-supplier { background-color: #16a34a !important; color:#fff; }
    .badge-role { font-size:0.72rem; font-weight:600; padding: 3px 10px; border-radius:4px; }

    .verified-icon   { color: var(--success); font-size:1.05rem; }
    .unverified-icon { color: var(--danger);  font-size:1.05rem; }

    .btn-action-edit   { border:1px solid var(--border-color); color: var(--text-muted); background:#fff; }
    .btn-action-edit:hover { background: var(--body-bg); color: var(--text-dark); }
    .btn-action-delete { border:1px solid var(--danger-border); color: var(--danger); background:#fff; }
    .btn-action-delete:hover { background: var(--danger-bg); color: #b91c1c; }

    .offcanvas-header .offcanvas-title { font-weight:700; color: var(--text-dark); font-size:1.1rem; }

    #roleGroup .btn { font-weight:500; font-size:0.9rem; }
    #roleGroup .btn-check:checked + .btn-outline-danger  { background-color:#dc3545!important; border-color:#dc3545!important; color:#fff!important; }
    #roleGroup .btn-check:checked + .btn-outline-primary { background-color: var(--elira-navy)!important; border-color: var(--elira-navy)!important; color:#fff!important; }
    #roleGroup .btn-check:checked + .btn-outline-success { background-color:#16a34a!important; border-color:#16a34a!important; color:#fff!important; }

    .alert-caution { background: var(--warning-bg); border:1px solid var(--warning-border); color: #92400e; border-radius:8px; padding:1rem; font-size:0.85rem; }
</style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">User Management</h1>
        <p class="page-subtitle">Manage Admin, Customer, and Supplier accounts.</p>
    </div>
    <button class="btn btn-elira-dark" id="btnAddUser">
        <i class="fa-solid fa-user-plus me-2"></i>Add User
    </button>
</div>

<div class="content-card fade-in-up">
    <div class="table-responsive">
        <table class="table align-middle m-0 elira-table" id="usersTable">
            <thead>
                <tr>
                    <th style="width:7%">ID</th>
                    <th style="width:11%">Role</th>
                    <th style="width:20%">Name / Company</th>
                    <th style="width:22%">Email</th>
                    <th style="width:13%">Phone</th>
                    <th style="width:9%">Verified</th>
                    <th style="width:13%">Created</th>
                    <th style="width:10%" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody id="userTableBody"></tbody>
        </table>
    </div>
</div>

<!-- ── ADD / EDIT OFFCANVAS ── -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="userOffcanvas" style="width:490px;">
    <div class="offcanvas-header border-bottom py-3">
        <h5 class="offcanvas-title" id="offcanvasTitle">Add New User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">

        <div id="roleSelectWrapper" class="mb-4">
            <label class="form-label mb-2">Account Type</label>
            <div class="btn-group w-100" role="group" id="roleGroup">
                <input type="radio" class="btn-check" name="roleSelect" id="roleAdmin"    value="Admin"    autocomplete="off" checked>
                <label class="btn btn-outline-danger"  for="roleAdmin">Admin</label>

                <input type="radio" class="btn-check" name="roleSelect" id="roleCustomer" value="Customer" autocomplete="off">
                <label class="btn btn-outline-primary" for="roleCustomer">Customer</label>

                <input type="radio" class="btn-check" name="roleSelect" id="roleSupplier" value="Supplier" autocomplete="off">
                <label class="btn btn-outline-success" for="roleSupplier">Supplier</label>
            </div>
        </div>

        <input type="hidden" id="editUserId" value="0" />
        <input type="hidden" id="editMode" value="create" />

        <div class="mb-3">
            <label class="form-label">Email <span class="text-danger">*</span></label>
            <input type="email" class="form-control" id="fEmail" placeholder="user@example.com" />
            <div class="invalid-feedback" id="fEmailErr"></div>
        </div>

        <div class="mb-3">
            <label class="form-label" id="passwordLabel">Password <span class="text-danger">*</span></label>
            <div class="input-group">
                <input type="password" class="form-control" id="fPassword" placeholder="Min 6 characters" />
                <button class="btn btn-outline-secondary" type="button" id="togglePassword"><i class="bi bi-eye"></i></button>
            </div>
            <div class="form-text text-muted small" id="passwordHint"></div>
            <div class="invalid-feedback" id="fPasswordErr"></div>
        </div>

        <div class="mb-4 form-check">
            <input type="checkbox" class="form-check-input" id="fIsEmailVerified" checked>
            <label class="form-check-label" for="fIsEmailVerified">Email Verified</label>
        </div>

        <!-- Customer fields -->
        <div id="customerFields" style="display:none">
            <hr><p class="fw-semibold small text-uppercase mb-3" style="color: var(--elira-navy); letter-spacing:.05em;">Customer Details</p>

            <div class="mb-3">
                <label class="form-label">Full Name <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="fFullName" placeholder="John Doe" />
                <div class="invalid-feedback" id="fFullNameErr"></div>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label">Phone</label>
                    <input type="text" class="form-control" id="fPhoneNo" placeholder="+92 300 0000000" />
                    <div class="invalid-feedback" id="fPhoneNoErr"></div>
                </div>
                <div class="col-6">
                    <label class="form-label">Gender</label>
                    <select class="form-select" id="fGender">
                        <option value="">Select</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Date of Birth</label>
                <input type="date" class="form-control" id="fDob" />
                <div class="invalid-feedback" id="fDobErr"></div>
            </div>
            <hr><p class="fw-semibold small text-uppercase mb-3" style="color: var(--elira-navy); letter-spacing:.05em;">Address</p>
            <div class="mb-3">
                <label class="form-label">Address Line <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="fAddressLine" placeholder="Street, Building, etc." />
                <div class="invalid-feedback" id="fAddressLineErr"></div>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label">City</label>
                    <input type="text" class="form-control" id="fCity" placeholder="Lahore" />
                </div>
                <div class="col-6">
                    <label class="form-label">Postal Code</label>
                    <input type="text" class="form-control" id="fPostalCode" placeholder="54000" />
                    <div class="invalid-feedback" id="fPostalCodeErr"></div>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Country</label>
                <input type="text" class="form-control" id="fCountry" placeholder="Pakistan" />
            </div>
        </div>

        <!-- Supplier fields -->
        <div id="supplierFields" style="display:none">
            <hr><p class="fw-semibold small text-uppercase mb-3" style="color: var(--success); letter-spacing:.05em;">Supplier Details</p>
            <div class="mb-3">
                <label class="form-label">Supplier Name <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="fSupplierName" placeholder="ABC Textiles Ltd" />
                <div class="invalid-feedback" id="fSupplierNameErr"></div>
            </div>
            <div class="mb-3">
                <label class="form-label">Contact Person</label>
                <input type="text" class="form-control" id="fContactPerson" placeholder="Ali Khan" />
            </div>
            <div class="mb-3">
                <label class="form-label">Phone</label>
                <input type="text" class="form-control" id="fSupplierPhone" placeholder="+92 300 0000000" />
                <div class="invalid-feedback" id="fSupplierPhoneErr"></div>
            </div>
            <div class="mb-3">
                <label class="form-label">Address</label>
                <textarea class="form-control" id="fSupplierAddress" rows="3" placeholder="Full address..."></textarea>
            </div>
        </div>

        <!-- Admin fields -->
        <div id="adminFields">
            <hr><p class="fw-semibold text-danger small text-uppercase mb-3" style="letter-spacing:.05em;">Admin Account</p>
            <div class="alert-caution d-flex align-items-start gap-2">
                <i class="bi bi-shield-lock" style="font-size:1.1rem; flex-shrink:0;"></i>
                <div>Admin accounts have full system access.<br>Create with caution.</div>
            </div>
        </div>
    </div>

    <div class="offcanvas-footer border-top p-3 d-flex justify-content-between align-items-center">
        <button class="btn btn-outline-secondary" data-bs-dismiss="offcanvas">Cancel</button>
        <button class="btn btn-elira-dark" id="btnSaveUser">
            <i class="fa-solid fa-floppy-disk me-1"></i> Save User
        </button>
    </div>
</div>

<!-- ── DELETE CONFIRM MODAL ── -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-3">
                <h5 class="modal-title fw-bold">Delete User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">Are you sure you want to delete <strong id="deleteUserName"></strong>?</p>
                <p class="text-danger small mb-0"><i class="bi bi-exclamation-triangle me-1"></i>This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-outline-secondary btn-sm px-3" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger btn-sm px-3" id="btnConfirmDelete">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let usersList = [];
    let deleteTargetId = null;
    const bsOffcanvas  = new bootstrap.Offcanvas(document.getElementById('userOffcanvas'));
    const bsDeleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

    document.addEventListener('DOMContentLoaded', () => { loadUsers(); });

    // ── Data loading ──────────────────────────────────────────
    async function loadUsers() {
        try {
            const response = await fetch('/Users/GetUsers');
            usersList = await response.json();
            renderTable();
        } catch (error) {
            console.error('Error loading users:', error);
            showToast('Failed to load users from the server.', 'error');
        }
    }

    function renderTable() {
        const tbody = document.getElementById('userTableBody');
        tbody.innerHTML = '';

        if (usersList.length === 0) {
            tbody.innerHTML = `<tr><td colspan="8" class="text-center text-muted py-5 small">
                <i class="fa-solid fa-users-slash me-2"></i>No users found.</td></tr>`;
            return;
        }

        usersList.forEach(u => {
            const roleClass = u.roleName === 'Admin' ? 'badge-role-admin'
                           : u.roleName === 'Customer' ? 'badge-role-customer' : 'badge-role-supplier';

            const displayName  = u.roleName === 'Customer' ? (u.fullName     || '—')
                               : u.roleName === 'Supplier' ? (u.supplierName || '—') : '—';
            const displayPhone = u.roleName === 'Customer' ? (u.phoneNo      || '—')
                               : u.roleName === 'Supplier' ? (u.supplierPhone|| '—') : '—';

            const verifiedIcon = u.isEmailVerified
                ? '<i class="bi bi-check-circle-fill verified-icon"></i>'
                : '<i class="bi bi-x-circle-fill unverified-icon"></i>';

            const dateFormatted = new Date(u.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' });

            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="text-muted">#${u.userId}</td>
                <td><span class="badge badge-role ${roleClass}">${u.roleName}</span></td>
                <td class="fw-medium">${displayName}</td>
                <td>${u.email}</td>
                <td class="text-muted">${displayPhone}</td>
                <td>${verifiedIcon}</td>
                <td class="text-muted small">${dateFormatted}</td>
                <td>
                    <div class="d-flex justify-content-center gap-1">
                        <button class="btn btn-sm btn-action-edit btn-action rounded" onclick="editUser(${u.userId})" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-sm btn-action-delete btn-action rounded" onclick="prepDelete(${u.userId})" title="Delete">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </td>`;
            tbody.appendChild(tr);
        });
    }

    // ── Role switch ───────────────────────────────────────────
    function handleRoleSwitch(role) {
        document.getElementById('customerFields').style.display = role === 'Customer' ? 'block' : 'none';
        document.getElementById('supplierFields').style.display = role === 'Supplier' ? 'block' : 'none';
        document.getElementById('adminFields').style.display    = role === 'Admin'    ? 'block' : 'none';
    }

    document.querySelectorAll('input[name="roleSelect"]').forEach(r =>
        r.addEventListener('change', e => handleRoleSwitch(e.target.value)));

    document.getElementById('togglePassword').addEventListener('click', function () {
        const input = document.getElementById('fPassword');
        const icon  = this.querySelector('i');
        const visible = input.type === 'text';
        input.type = visible ? 'password' : 'text';
        icon.className = visible ? 'bi bi-eye' : 'bi bi-eye-slash';
    });

    // ── Form helpers ──────────────────────────────────────────
    function resetForm() {
        const formInputIds = new Array(
            'editUserId','fEmail','fPassword','fFullName','fPhoneNo','fGender','fDob',
            'fAddressLine','fCity','fPostalCode','fCountry',
            'fSupplierName','fContactPerson','fSupplierPhone','fSupplierAddress'
        );
        formInputIds.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.value = '';
        });
        document.getElementById('editUserId').value       = '0';
        document.getElementById('editMode').value         = 'create';
        document.getElementById('fIsEmailVerified').checked = true;
        document.getElementById('passwordLabel').innerHTML  = 'Password <span class="text-danger">*</span>';
        document.getElementById('passwordHint').innerText   = '';
        
        document.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));
        
        const feedbackIds = new Array(
            'fEmailErr', 'fPasswordErr', 'fFullNameErr', 'fAddressLineErr',
            'fPhoneNoErr', 'fDobErr', 'fPostalCodeErr',
            'fSupplierNameErr', 'fSupplierPhoneErr'
        );
        feedbackIds.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.innerText = '';
        });
    }

    document.getElementById('btnAddUser').addEventListener('click', () => {
        resetForm();
        document.getElementById('offcanvasTitle').innerText = 'Add New User';
        document.getElementById('roleSelectWrapper').classList.remove('d-none');
        document.getElementById('roleAdmin').checked = true;
        handleRoleSwitch('Admin');
        bsOffcanvas.show();
    });

    window.editUser = function (id) {
        resetForm();
        const user = usersList.find(u => u.userId === id);
        if (!user) return;

        document.getElementById('offcanvasTitle').innerText    = 'Edit User';
        document.getElementById('editUserId').value            = user.userId;
        document.getElementById('editMode').value              = 'edit';
        document.getElementById('roleSelectWrapper').classList.add('d-none');
        document.getElementById('fEmail').value                = user.email;
        document.getElementById('fIsEmailVerified').checked    = user.isEmailVerified;
        document.getElementById('passwordLabel').innerText     = 'Change Password';
        document.getElementById('passwordHint').innerText      = 'Leave blank to keep existing password.';

        handleRoleSwitch(user.roleName);

        if (user.roleName === 'Customer') {
            document.getElementById('fFullName').value    = user.fullName    || '';
            document.getElementById('fPhoneNo').value     = user.phoneNo     || '';
            document.getElementById('fGender').value      = user.gender      || '';
            document.getElementById('fDob').value         = user.dateOfBirth || '';
            document.getElementById('fAddressLine').value = user.addressLine || '';
            document.getElementById('fCity').value        = user.city        || '';
            document.getElementById('fPostalCode').value  = user.postalCode  || '';
            document.getElementById('fCountry').value     = user.country     || '';
        } else if (user.roleName === 'Supplier') {
            document.getElementById('fSupplierName').value    = user.supplierName    || '';
            document.getElementById('fContactPerson').value   = user.contactPerson   || '';
            document.getElementById('fSupplierPhone').value   = user.supplierPhone   || '';
            document.getElementById('fSupplierAddress').value = user.supplierAddress || '';
        }

        bsOffcanvas.show();
    };

    // ── Save user ─────────────────────────────────────────────
    document.getElementById('btnSaveUser').addEventListener('click', async () => {
        document.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));
        
        const feedbackIds = new Array(
            'fEmailErr', 'fPasswordErr', 'fFullNameErr', 'fAddressLineErr',
            'fPhoneNoErr', 'fDobErr', 'fPostalCodeErr',
            'fSupplierNameErr', 'fSupplierPhoneErr'
        );
        feedbackIds.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.innerText = '';
        });

        const mode       = document.getElementById('editMode').value;
        const id         = parseInt(document.getElementById('editUserId').value);
        const activeRole = mode === 'create'
            ? document.querySelector('input[name="roleSelect"]:checked').value
            : usersList.find(u => u.userId === id).roleName;

        const emailInput = document.getElementById('fEmail');
        const passwordInput = document.getElementById('fPassword');
        const emailVal = emailInput.value.trim();
        const passwordVal = passwordInput.value;

        let hasError = false;

        // Email validation
        if (!emailVal) {
            emailInput.classList.add('is-invalid');
            document.getElementById('fEmailErr').innerText = 'Email is required.';
            hasError = true;
        } else {
            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!emailRegex.test(emailVal)) {
                emailInput.classList.add('is-invalid');
                document.getElementById('fEmailErr').innerText = 'Invalid email format.';
                hasError = true;
            }
        }

        // Password validation: min 8 characters, uppercase, lowercase, digit, and special character
        const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^a-zA-Z\d]).{8,}$/;
        if (mode === 'create') {
            if (!passwordVal) {
                passwordInput.classList.add('is-invalid');
                document.getElementById('fPasswordErr').innerText = 'Password is required.';
                hasError = true;
            } else if (!passwordRegex.test(passwordVal)) {
                passwordInput.classList.add('is-invalid');
                document.getElementById('fPasswordErr').innerText = 'Password must be at least 8 characters and contain at least one uppercase letter, one lowercase letter, one digit, and one special character.';
                hasError = true;
            }
        } else {
            if (passwordVal && !passwordRegex.test(passwordVal)) {
                passwordInput.classList.add('is-invalid');
                document.getElementById('fPasswordErr').innerText = 'Password must be at least 8 characters and contain at least one uppercase letter, one lowercase letter, one digit, and one special character.';
                hasError = true;
            }
        }

        const payload = {
            userId: id,
            email: emailVal,
            password: passwordVal,
            isEmailVerified: document.getElementById('fIsEmailVerified').checked,
            roleName: activeRole
        };

        if (activeRole === 'Customer') {
            const fullNameInput = document.getElementById('fFullName');
            const addressInput = document.getElementById('fAddressLine');
            const phoneInput = document.getElementById('fPhoneNo');
            const dobInput = document.getElementById('fDob');
            const postalInput = document.getElementById('fPostalCode');

            const fullNameVal = fullNameInput.value.trim();
            const addressVal = addressInput.value.trim();
            const phoneVal = phoneInput.value.trim();
            const dobVal = dobInput.value;
            const postalVal = postalInput.value.trim();

            if (!fullNameVal) {
                fullNameInput.classList.add('is-invalid');
                document.getElementById('fFullNameErr').innerText = 'Full Name is required.';
                hasError = true;
            }
            if (!addressVal) {
                addressInput.classList.add('is-invalid');
                document.getElementById('fAddressLineErr').innerText = 'Address Line is required.';
                hasError = true;
            }
            if (phoneVal) {
                const phoneRegex = /^\+?[0-9\s\-]{7,15}$/;
                if (!phoneRegex.test(phoneVal)) {
                    phoneInput.classList.add('is-invalid');
                    document.getElementById('fPhoneNoErr').innerText = 'Invalid phone number format.';
                    hasError = true;
                }
            }
            if (postalVal) {
                const numericRegex = /^\d+$/;
                if (!numericRegex.test(postalVal)) {
                    postalInput.classList.add('is-invalid');
                    document.getElementById('fPostalCodeErr').innerText = 'Postal Code must contain numeric characters only.';
                    hasError = true;
                }
            }
            if (dobVal) {
                const dobDate = new Date(dobVal);
                const today = new Date();
                if (dobDate > today) {
                    dobInput.classList.add('is-invalid');
                    document.getElementById('fDobErr').innerText = 'Date of Birth cannot be set in the future.';
                    hasError = true;
                }
            }

            payload.customer = {
                fullName:    fullNameVal,
                phoneNo:     phoneVal,
                address:     addressVal,
                gender:      document.getElementById('fGender').value,
                dateOfBirth: dobVal || null,
                city:        document.getElementById('fCity').value.trim(),
                postalCode:  postalVal,
                country:     document.getElementById('fCountry').value.trim()
            };
        } else if (activeRole === 'Supplier') {
            const supplierNameInput = document.getElementById('fSupplierName');
            const supplierPhoneInput = document.getElementById('fSupplierPhone');

            const supplierNameVal = supplierNameInput.value.trim();
            const supplierPhoneVal = supplierPhoneInput.value.trim();

            if (!supplierNameVal) {
                supplierNameInput.classList.add('is-invalid');
                document.getElementById('fSupplierNameErr').innerText = 'Supplier Name is required.';
                hasError = true;
            }
            if (supplierPhoneVal) {
                const phoneRegex = /^\+?[0-9\s\-]{7,15}$/;
                if (!phoneRegex.test(supplierPhoneVal)) {
                    supplierPhoneInput.classList.add('is-invalid');
                    document.getElementById('fSupplierPhoneErr').innerText = 'Invalid supplier phone format.';
                    hasError = true;
                }
            }

            payload.supplier = {
                supplierName:  supplierNameVal,
                contactPerson: document.getElementById('fContactPerson').value.trim(),
                phone:         supplierPhoneVal,
                address:       document.getElementById('fSupplierAddress').value.trim()
            };
        }

        if (hasError) {
            return;
        }

        try {
            const response = await fetch('/Users/Save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const result = await response.json();

            if (result.success) {
                bsOffcanvas.hide();
                showToast(`User successfully ${mode === 'create' ? 'created' : 'updated'}.`, 'success');
                await loadUsers();
            } else if (result.errors) {
                const fieldMap = {
                    email: 'fEmail', password: 'fPassword', fullName: 'fFullName',
                    address: 'fAddressLine', supplierName: 'fSupplierName'
                };
                const errMap = {
                    email: 'fEmailErr', password: 'fPasswordErr', fullName: 'fFullNameErr',
                    address: 'fAddressLineErr', supplierName: 'fSupplierNameErr'
                };
                for (const [key, msg] of Object.entries(result.errors)) {
                    if (fieldMap[key]) document.getElementById(fieldMap[key])?.classList.add('is-invalid');
                    if (errMap[key])   document.getElementById(errMap[key]).innerText = msg;
                }
            } else {
                showToast(result.message || 'An error occurred while saving the user.', 'error');
            }
        } catch (error) {
            console.error('Error saving user:', error);
            showToast('Failed to communicate with the server.', 'error');
        }
    });

    // ── Delete ────────────────────────────────────────────────
    window.prepDelete = function (id) {
        const user = usersList.find(u => u.userId === id);
        if (!user) return;
        deleteTargetId = id;
        document.getElementById('deleteUserName').innerText = user.email;
        bsDeleteModal.show();
    };

    document.getElementById('btnConfirmDelete').addEventListener('click', async () => {
        if (deleteTargetId !== null) {
            try {
                const response = await fetch(`/Users/Delete?id=${deleteTargetId}`, { method: 'POST' });
                const result   = await response.json();
                if (result.success) {
                    bsDeleteModal.hide();
                    showToast('User successfully deleted.', 'success');
                    await loadUsers();
                } else {
                    showToast(result.message || 'Failed to delete user.', 'error');
                }
            } catch (error) {
                console.error('Error deleting user:', error);
                showToast('Failed to communicate with the server.', 'error');
            }
        }
    });
</script>
}
