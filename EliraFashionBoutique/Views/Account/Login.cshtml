@model EliraFashionBoutique.Models.LoginViewModel
@{
    Layout = null;
    var emailHasError = ViewData.ModelState["Email"]?.Errors.Any() == true;
    var emailErrorMsg = emailHasError ? ViewData.ModelState["Email"]?.Errors.FirstOrDefault()?.ErrorMessage : "";

    var passwordHasError = ViewData.ModelState["Password"]?.Errors.Any() == true;
    var passwordErrorMsg = passwordHasError ? ViewData.ModelState["Password"]?.Errors.FirstOrDefault()?.ErrorMessage : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ELIRA Fashion Boutique | Sign In</title>

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
  /* ============================================
     RESET & BASE
  ============================================ */
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root{
    --c-deepest:   #081526;
    --c-navy:      #0D1B34;
    --c-blue-2:    #102B52;
    --c-blue-3:    #183B70;
    --c-accent:    #4F8EF7;
    --c-gold:      #C9A24B;
    --c-text:      #FAF3E8;
    --c-text-dim:  #D9C9AE;
    --glass-bg:    rgba(13, 27, 52, 0.35);
    --glass-border: rgba(255, 255, 255, 0.16);
    --radius-card: 25px;
  }

  html, body {
    height: 100%;
    width: 100%;
    overflow-x: hidden;
  }

  body {
    font-family: 'Poppins', sans-serif;
    color: var(--c-text);
    background: var(--c-deepest);
  }

  /* ============================================
     BACKGROUND VIDEO
  ============================================ */
  .video-wrapper {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    z-index: 0;
  }

  #bg-video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: cover;
    object-position: center 30%;
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(4,13,28,.28) 0%, rgba(4,13,28,.34) 55%, rgba(4,13,28,.46) 100%);
  }

  /* ============================================
     LAYOUT
  ============================================ */
  .page {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  /* ============================================
     LOGIN CARD — Glassmorphism
  ============================================ */
  .login-card {
    width: 100%;
    max-width: 380px;
    background: linear-gradient(160deg, rgba(28, 20, 12, 0.38) 0%, rgba(20, 14, 8, 0.30) 100%);
    border: 1px solid rgba(201, 162, 75, 0.55);
    border-radius: var(--radius-card);
    backdrop-filter: blur(6px) saturate(140%);
    -webkit-backdrop-filter: blur(6px) saturate(140%);
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(201, 162, 75, 0.15),
      0 0 50px rgba(201, 162, 75, 0.14),
      0 2px 0 rgba(255,255,255,0.18) inset;
    padding: 22px 34px 26px;
    position: relative;
    opacity: 0;
    animation: fadeInUp 1.1s cubic-bezier(.22,.9,.32,1) forwards, floatCard 6s ease-in-out 1.2s infinite;
  }

  @@keyframes fadeInUp {
    0%   { opacity: 0; transform: translateY(38px) scale(.97); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  @@keyframes floatCard {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-9px); }
  }

  /* inner gold frame for an elegant double-border effect */
  .login-card::after {
    content: "";
    position: absolute;
    inset: 8px;
    border: 1px solid rgba(201, 162, 75, 0.22);
    border-radius: calc(var(--radius-card) - 10px);
    pointer-events: none;
  }

  /* subtle gold sheen line */
  .login-card::before {
    content: "";
    position: absolute;
    top: 0; left: 12%; right: 12%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(201,162,75,.9), transparent);
    z-index: 1;
  }

  /* ============================================
     LOGO
  ============================================ */
  .logo-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: -20px;
  }

  .logo-wrap img {
    max-width: 145px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 4px 14px rgba(0,0,0,.4));
  }

  /* ============================================
     HEADER TEXT
  ============================================ */
  .card-heading {
    text-align: center;
    margin-bottom: 18px;
  }

  .card-heading h1 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 800;
    font-size: 22px;
    letter-spacing: 0.5px;
    background: linear-gradient(180deg, #FFFFFF 10%, var(--c-text-dim) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 6px;
  }

  .card-heading p {
    font-size: 13.5px;
    font-weight: 600;
    letter-spacing: 0.3px;
    color: var(--c-text-dim);
  }

  /* ============================================
     FORM
  ============================================ */
  form { display: flex; flex-direction: column; gap: 14px; }

  .field-group {
    position: relative;
  }

  .field-label {
    display: block;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--c-text-dim);
    margin-bottom: 8px;
  }

  .input-shell {
    position: relative;
    display: flex;
    align-items: center;
    background: rgba(255, 252, 245, 0.18);
    border: 1px solid rgba(201, 162, 75, 0.30);
    border-radius: 12px;
    overflow: hidden; /* Prevent child backgrounds from overflowing rounded corners */
    transition: border-color .35s ease, box-shadow .35s ease, background .35s ease;
  }

  .input-shell:focus-within {
    border-color: var(--c-gold);
    background: rgba(201, 162, 75, 0.10);
    box-shadow: 0 0 0 4px rgba(201, 162, 75, 0.16), 0 8px 18px rgba(0,0,0,.25);
  }

  .input-shell i.icon-left {
    padding-left: 16px;
    color: var(--c-gold);
    font-size: 14px;
    opacity: 0.85;
    width: 18px;
    text-align: center;
  }

  .input-shell input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    color: var(--c-text);
    font-family: 'Poppins', sans-serif;
    font-size: 14.5px;
    font-weight: 600;
    padding: 12px 16px;
    letter-spacing: 0.2px;
    border-radius: 12px 0 0 12px; /* Ensure input shape matches shell on the left */
  }

  .input-shell input:only-child {
    border-radius: 12px; /* Ensure full rounded corners for inputs without side buttons */
  }

  .input-shell input::placeholder {
    color: rgba(250, 243, 232, 0.45);
    font-weight: 300;
  }

  /* Prevent browser autofill from breaking textfield background/shape */
  .input-shell input:-webkit-autofill,
  .input-shell input:-webkit-autofill:hover, 
  .input-shell input:-webkit-autofill:focus, 
  .input-shell input:-webkit-autofill:active {
    -webkit-box-shadow: 0 0 0 1000px #211912 inset !important; /* Premium dark background matching card */
    -webkit-text-fill-color: var(--c-text) !important;
    caret-color: var(--c-text);
    transition: background-color 5000s ease-in-out 0s;
  }

  /* Match shell background with autofill background for uniform look */
  .input-shell:has(input:-webkit-autofill) {
    background: #211912 !important;
  }

  .toggle-eye {
    background: none;
    border: none;
    color: var(--c-text-dim);
    cursor: pointer;
    font-size: 14px;
    padding: 0 16px;
    transition: color .25s ease, transform .2s ease;
  }

  .toggle-eye:hover { color: var(--c-accent); transform: scale(1.08); }

  /* inline validation message */
  .error-msg {
    display: none;
    align-items: center;
    gap: 6px;
    margin-top: 7px;
    font-size: 12px;
    color: #FF8FA3;
    letter-spacing: .2px;
    animation: shake .35s ease;
  }

  .error-msg.show { display: flex; }

  .field-group.has-error .input-shell {
    border-color: #E0566F;
    box-shadow: 0 0 0 4px rgba(224, 86, 111, 0.12);
  }

  @@keyframes shake {
    0%, 100% { transform: translateX(0); }
    20%      { transform: translateX(-5px); }
    40%      { transform: translateX(5px); }
    60%      { transform: translateX(-3px); }
    80%      { transform: translateX(3px); }
  }

  /* ============================================
     ROW: remember / forgot
  ============================================ */
  .form-meta {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-top: -6px;
  }

  .forgot-link {
    font-size: 12.5px;
    color: var(--c-gold);
    text-decoration: none;
    font-weight: 400;
    letter-spacing: 0.2px;
    position: relative;
    transition: color .25s ease;
  }

  .forgot-link::after {
    content: "";
    position: absolute;
    left: 0; bottom: -2px;
    width: 0%;
    height: 1px;
    background: var(--c-gold);
    transition: width .3s ease;
  }

  .forgot-link:hover::after { width: 100%; }

  /* ============================================
     BUTTON
  ============================================ */
  .btn-signin {
    margin-top: 2px;
    width: 100%;
    padding: 13px;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    font-family: 'Poppins', sans-serif;
    font-size: 14.5px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: #1a1208;
    background: linear-gradient(135deg, #E8C97A 0%, var(--c-gold) 48%, #8A6A2F 100%);
    background-size: 200% 200%;
    background-position: 0% 50%;
    box-shadow: 0 14px 28px rgba(120, 90, 30, 0.45), 0 0 0 1px rgba(255,255,255,0.08) inset;
    transition: transform .35s cubic-bezier(.2,.8,.2,1), box-shadow .35s ease, background-position .6s ease;
    position: relative;
    overflow: hidden;
  }

  .btn-signin span { position: relative; z-index: 2; }

  .btn-signin::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,.35) 50%, transparent 100%);
    transform: translateX(-120%);
    transition: transform .7s ease;
  }

  .btn-signin:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 38px rgba(201, 162, 75, 0.4), 0 0 24px rgba(201,162,75,.35), 0 0 0 1px rgba(255,255,255,0.08) inset;
    background-position: 100% 50%;
  }

  .btn-signin:hover::before { transform: translateX(120%); }

  .btn-signin:active { transform: translateY(-1px) scale(.99); }

  /* ============================================
     DIVIDER + FOOTER
  ============================================ */
  .divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 16px 0 12px;
  }

  .divider .line {
    flex: 1;
    height: 1px;
    background: rgba(201, 162, 75, 0.30);
  }

  .divider span {
    font-size: 11px;
    font-weight: 600;
    color: var(--c-text-dim);
    letter-spacing: 0.5px;
  }

  .signup-row {
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    color: var(--c-text-dim);
    margin-bottom: 14px;
  }

  .signup-row a {
    color: var(--c-gold);
    text-decoration: none;
    font-weight: 500;
  }

  .signup-row a:hover { text-decoration: underline; }

  .card-footer {
    text-align: center;
    font-size: 11px;
    letter-spacing: 0.4px;
    font-weight: 600;
    color: var(--c-text-dim);
    margin-top: 18px;
    padding-top: 12px;
    border-top: 1px solid rgba(201, 162, 75, 0.25);
  }

  /* ============================================
     RESPONSIVE
  ============================================ */
  @@media (max-width: 480px) {
    .login-card { padding: 38px 26px 26px; border-radius: 20px; }
    .card-heading h1 { font-size: 30px; }
  }

  @@media (max-width: 360px) {
    .login-card { padding: 30px 20px 22px; }
  }

  /* respect reduced motion preference */
  @@media (prefers-reduced-motion: reduce) {
    .login-card { animation: fadeInUp 0.6s ease forwards; }
  }

  /* visible focus ring for accessibility */
  a:focus-visible, button:focus-visible, input:focus-visible {
    outline: 2px solid var(--c-accent);
    outline-offset: 2px;
  }
</style>
</head>
<body>

  <!-- ============================================
       BACKGROUND VIDEO (HERO)
  ============================================ -->
  <div class="video-wrapper">
    <video id="bg-video" autoplay muted loop playsinline preload="auto">
      <source src="/videos/video.mp4" type="video/mp4">
    </video>
    <div class="video-overlay"></div>
  </div>

  <!-- ============================================
       PAGE / CARD
  ============================================ -->
  <main class="page">
    <section class="login-card" role="region" aria-label="Sign in to ELIRA Fashion Boutique">

      <div class="logo-wrap">
        <img src="~/images/logo.png" alt="ELIRA Fashion Boutique Logo" asp-append-version="true">
      </div>

      <div class="card-heading">
        <h1>Welcome Back</h1>
        <p>Sign in to manage your boutique.</p>
      </div>

      <form id="login-form" asp-action="Login" asp-controller="Account" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" novalidate>
        <input type="hidden" asp-for="RememberMe" value="false" />

        <div class="field-group @(emailHasError ? "has-error" : "")" id="email-group">
          <label class="field-label" for="email">Email Address</label>
          <div class="input-shell">
            <input type="email" id="email" asp-for="Email" placeholder="you@elira.com" autocomplete="email">
          </div>
          <div class="error-msg @(emailHasError ? "show" : "")" id="email-error">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span>@emailErrorMsg</span>
          </div>
        </div>

        <div class="field-group @(passwordHasError ? "has-error" : "")" id="password-group">
          <label class="field-label" for="password">Password</label>
          <div class="input-shell">
            <input type="password" id="password" asp-for="Password" placeholder="Enter your password" autocomplete="current-password">
            <button type="button" class="toggle-eye" id="toggle-password" aria-label="Show password">
              <i class="fa-regular fa-eye" id="eye-icon"></i>
            </button>
          </div>
          <div class="error-msg @(passwordHasError ? "show" : "")" id="password-error">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span>@passwordErrorMsg</span>
          </div>
        </div>

        <div class="form-meta">
          <a href="#" class="forgot-link">Forgot Password?</a>
        </div>

        <button type="submit" class="btn-signin"><span>Sign In</span></button>

      </form>

      <div class="card-footer">
        &copy; 2026 ELIRA Fashion Boutique
      </div>

    </section>
  </main>

  <script>
    // ============================================
    // PASSWORD SHOW / HIDE TOGGLE
    // ============================================
    const togglePasswordBtn = document.getElementById('toggle-password');
    const passwordInput = document.getElementById('password');
    const eyeIcon = document.getElementById('eye-icon');

    togglePasswordBtn.addEventListener('click', function () {
      const isHidden = passwordInput.type === 'password';
      passwordInput.type = isHidden ? 'text' : 'password';

      eyeIcon.classList.toggle('fa-eye', !isHidden);
      eyeIcon.classList.toggle('fa-eye-slash', isHidden);

      togglePasswordBtn.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
    });

    // ============================================
    // ELEGANT INLINE FORM VALIDATION & REAL POSTBACK
    // ============================================
    const loginForm = document.getElementById('login-form');
    const emailInput = document.getElementById('email');

    const emailGroup = document.getElementById('email-group');
    const passwordGroup = document.getElementById('password-group');

    const emailError = document.getElementById('email-error');
    const passwordError = document.getElementById('password-error');

    function setFieldError(group, errorEl, show, message) {
      if (show) {
        group.classList.add('has-error');
        errorEl.classList.add('show');
        if (message) errorEl.querySelector('span').textContent = message;
      } else {
        group.classList.remove('has-error');
        errorEl.classList.remove('show');
      }
    }

    function isValidEmail(value) {
      return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(value);
    }

    // Clear errors as the user starts correcting them
    emailInput.addEventListener('input', () => {
      if (emailInput.value.trim() !== '') setFieldError(emailGroup, emailError, false);
    });
    passwordInput.addEventListener('input', () => {
      if (passwordInput.value.trim() !== '') setFieldError(passwordGroup, passwordError, false);
    });

    loginForm.addEventListener('submit', function (e) {
      e.preventDefault();

      let valid = true;

      // Email checks
      if (emailInput.value.trim() === '') {
        setFieldError(emailGroup, emailError, true, 'Please enter your email address.');
        valid = false;
      } else if (!isValidEmail(emailInput.value.trim())) {
        setFieldError(emailGroup, emailError, true, 'Please enter a valid email address.');
        valid = false;
      } else {
        setFieldError(emailGroup, emailError, false);
      }

      // Password checks
      if (passwordInput.value.trim() === '') {
        setFieldError(passwordGroup, passwordError, true, 'Please enter your password.');
        valid = false;
      } else {
        setFieldError(passwordGroup, passwordError, false);
      }

      if (!valid) return;

      // Show a premium "signing in" state on the button
      const btn = loginForm.querySelector('.btn-signin');
      btn.innerHTML = '<span><i class="fa-solid fa-spinner fa-spin"></i>&nbsp; Signing In...</span>';
      btn.style.pointerEvents = 'none';

      // Submit the form to the backend after a brief delay for animation
      setTimeout(() => {
        loginForm.submit();
      }, 600);
    });

    // ============================================
    // ENSURE BACKGROUND VIDEO PLAYS ON MOBILE
    // ============================================
    const bgVideo = document.getElementById('bg-video');
    document.addEventListener('click', function tryPlay() {
      bgVideo.play().catch(() => {});
      document.removeEventListener('click', tryPlay);
    }, { once: true });
  </script>

</body>
</html>
