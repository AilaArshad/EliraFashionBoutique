@section Scripts {
    <script>
        // ============================================================
        // ReportsModule — handles tab switching + API integration
        // Base API URL: change this to match your Web API's actual port
        // ============================================================
        const ReportsModule = (function () {
            const API_BASE = "https://localhost:7027/api/Reports"; // <-- update port if different

            // Maps each tab key to its API endpoint + table renderer
            const config = {
                sales: {
                    endpoint: "/sales",
                    filters: ["startDate", "endDate", "categoryId", "status"],
                    render: renderSalesRows
                },
                customer: {
                    endpoint: "/customer-history",
                    filters: ["customerId", "startDate", "endDate"],
                    render: renderCustomerRows
                },
                product: {
                    endpoint: "/product-performance",
                    filters: ["startDate", "endDate"],
                    render: renderProductRows
                },
                inventory: {
                    endpoint: "/low-stock",
                    filters: ["subCategoryId"],
                    render: renderInventoryRows
                },
                purchase: {
                    endpoint: "/returns",
                    filters: ["startDate", "endDate", "returnStatus"],
                    render: renderPurchaseRows
                }
            };

            function initTabs() {
                document.querySelectorAll(".report-tab-btn").forEach(btn => {
                    btn.addEventListener("click", () => switchTab(btn.dataset.tab));
                });
            }

            function switchTab(tabKey) {
                document.querySelectorAll(".report-tab-btn").forEach(b => b.classList.remove("active"));
                document.querySelectorAll(".report-tab-panel").forEach(p => p.classList.remove("active"));

                document.querySelector(`.report-tab-btn[data-tab="${tabKey}"]`).classList.add("active");
                document.getElementById(`panel-${tabKey}`).classList.add("active");
            }

            // Builds query string from filter inputs that have a value
            function buildQuery(tabKey) {
                const cfg = config[tabKey];
                const params = new URLSearchParams();
                cfg.filters.forEach(f => {
                    const el = document.getElementById(`${tabKey}-${f}`);
                    if (el && el.value) {
                        // Capitalize first letter to match C# filter property names (StartDate, EndDate, etc.)
                        const paramName = f.charAt(0).toUpperCase() + f.slice(1);
                        params.append(paramName, el.value);
                    }
                });
                return params.toString();
            }

            // Calls the real API endpoint and renders results
            async function load(tabKey) {
                const cfg = config[tabKey];
                const tbody = document.querySelector(`#${tabKey}-table tbody`);
                const emptyState = document.getElementById(`${tabKey}-empty`);

                tbody.innerHTML = `<tr><td colspan="10" class="report-loading">Loading ${tabKey} report...</td></tr>`;
                emptyState.style.display = "none";

                try {
                    const query = buildQuery(tabKey);
                    const url = `${API_BASE}${cfg.endpoint}${query ? "?" + query : ""}`;

                    const response = await fetch(url);
                    if (!response.ok) throw new Error(`API returned ${response.status}`);

                    const data = await response.json();

                    tbody.innerHTML = "";
                    if (!data || data.length === 0) {
                        emptyState.style.display = "block";
                        emptyState.querySelector(":not(.empty-icon)") || null;
                        emptyState.innerHTML = `<div class="empty-icon">📭</div> No records found for the selected filters.`;
                        return;
                    }

                    cfg.render(data, tbody);
                } catch (err) {
                    console.error(`Error loading ${tabKey} report:`, err);
                    tbody.innerHTML = `<tr><td colspan="10" class="report-loading">Failed to load report. Please check API connection.</td></tr>`;
                }
            }

            // ---- Renderers: map JSON response -> table rows ----
            function renderSalesRows(data, tbody) {
                data.forEach(row => {
                    tbody.innerHTML += `
                        <tr>
                            <td>#${row.orderId}</td>
                            <td>${formatDate(row.orderDate)}</td>
                            <td>${statusPill(row.status)}</td>
                            <td>${row.customerName ?? "-"}</td>
                            <td>${row.productName ?? "-"}</td>
                            <td>${row.categoryName ?? "-"}</td>
                            <td>${row.quantity}</td>
                            <td>${formatCurrency(row.unitPrice)}</td>
                            <td>${formatCurrency(row.discountedAmount)}</td>
                            <td>${formatCurrency(row.finalAmount)}</td>
                        </tr>`;
                });
            }

            function renderCustomerRows(data, tbody) {
                data.forEach(row => {
                    tbody.innerHTML += `
                        <tr>
                            <td>${row.customerId}</td>
                            <td>${row.fullName ?? "-"}</td>
                            <td>${row.email ?? "-"}</td>
                            <td>${row.phoneNo ?? "-"}</td>
                            <td>${row.totalOrders}</td>
                            <td>${formatCurrency(row.totalSpent)}</td>
                            <td>${row.lastOrderDate ? formatDate(row.lastOrderDate) : "-"}</td>
                        </tr>`;
                });
            }

            function renderProductRows(data, tbody) {
                data.forEach(row => {
                    tbody.innerHTML += `
                        <tr>
                            <td>${row.productId}</td>
                            <td>${row.productName ?? "-"}</td>
                            <td>${row.subcategoryName ?? "-"}</td>
                            <td>${row.totalUnitsSold}</td>
                            <td>${formatCurrency(row.totalRevenue)}</td>
                            <td>${row.numberOfOrders}</td>
                        </tr>`;
                });
            }

            function renderInventoryRows(data, tbody) {
                data.forEach(row => {
                    tbody.innerHTML += `
                        <tr>
                            <td>${row.productName ?? "-"}</td>
                            <td>${row.variantSKU ?? "-"}</td>
                            <td>${row.sizeName ?? "-"}</td>
                            <td>${row.colorName ?? "-"}</td>
                            <td>${row.quantityAvailable}</td>
                            <td>${row.reorderLevel}</td>
                            <td><strong>${row.unitsNeeded}</strong></td>
                            <td>${row.subcategoryName ?? "-"}</td>
                        </tr>`;
                });
            }

            function renderPurchaseRows(data, tbody) {
                data.forEach(row => {
                    tbody.innerHTML += `
                        <tr>
                            <td>#${row.returnId}</td>
                            <td>#${row.orderId}</td>
                            <td>${formatDate(row.returnDate)}</td>
                            <td>${statusPill(row.returnStatus)}</td>
                            <td>${row.productName ?? "-"}</td>
                            <td>${row.variantSKU ?? "-"}</td>
                            <td>${row.quantityReturned}</td>
                            <td>${row.refundAmount ? formatCurrency(row.refundAmount) : "-"}</td>
                            <td>${row.refundStatus ?? "-"}</td>
                        </tr>`;
                });
            }

            // ---- Helpers ----
            function formatDate(value) {
                const d = new Date(value);
                return d.toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" });
            }

            function formatCurrency(value) {
                if (value === null || value === undefined) return "-";
                return "PKR " + Number(value).toLocaleString();
            }

            function statusPill(status) {
                const cls = (status || "").toLowerCase();
                let pillClass = "status-pending";
                if (cls.includes("delivered") || cls.includes("approved") || cls.includes("processed")) pillClass = "status-delivered";
                else if (cls.includes("pending")) pillClass = "status-pending";
                return `<span class="status-pill ${pillClass}">${status ?? "-"}</span>`;
            }

            // ---- Export placeholders (wire to your real export endpoints) ----
            function exportReport(tabKey, type) {
                const cfg = config[tabKey];
                const query = buildQuery(tabKey);
                const url = `${API_BASE}${cfg.endpoint}/export/${type}${query ? "?" + query : ""}`;
                // Opens the export endpoint directly -- browser will download the file
                window.open(url, "_blank");
            }

            return { initTabs, load, exportReport };
        })();

        document.addEventListener("DOMContentLoaded", () => {
            ReportsModule.initTabs();
            // Optionally auto-load the Sales tab on page load:
            // ReportsModule.load('sales');
        });
    </script>
}
