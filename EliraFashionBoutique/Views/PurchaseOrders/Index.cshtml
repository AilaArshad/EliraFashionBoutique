@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elira Fashion Boutique - Purchase Orders</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --text-dark: #0f172a;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
            --body-bg: #f8fafc;
            --btn-dark-navy: #1b223c;
            --btn-dark-navy-hover: #12182c;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-dark);
            overflow-x: hidden;
        }
        
        .main-content {
            padding: 2rem;
            width: 100%;
            flex-grow: 1;
            min-width: 0;
        }
        
        .content-card {
            background: #fff;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            margin-bottom: 24px;
            box-shadow: 0 1px 2px rgba(0,0,0,0.02);
        }
        .card-title-bar {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
            background-color: #fff;
            font-weight: 600;
        }

        .btn-custom-dark {
            background-color: var(--btn-dark-navy);
            color: #ffffff;
            border: 1px solid var(--btn-dark-navy);
        }
        .btn-custom-dark:hover, .btn-custom-dark:focus {
            background-color: var(--btn-dark-navy-hover);
            color: #ffffff;
            border-color: var(--btn-dark-navy-hover);
        }

        .header-container {
            flex-wrap: wrap;
            gap: 1rem;
        }

        .table-responsive {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            width: 100%;
        }
        
        .table th {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            background-color: #f8fafc;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
        }
        .table td {
            padding: 12px 10px;
            font-size: 0.85rem;
            color: #334155;
            vertical-align: middle;
        }

        .col-w-subcat { min-width: 220px !important; }
        .col-w-prod { min-width: 220px !important; }
        .col-w-sku { min-width: 300px !important; }
        .col-w-qty { min-width: 90px !important; width: 90px; }
        .col-w-cost { min-width: 130px !important; width: 130px; }
        .col-w-subtotal { min-width: 150px !important; width: 150px; }

        tr.active-row {
            background-color: #f1f5f9 !important;
            border-left: 4px solid #3b82f6;
        }

        .status-dropdown {
            font-size: 0.75rem;
            font-weight: 600;
            padding: 6px 12px;
            border-radius: 6px;
            border: 1px solid transparent;
        }
        .status-approved { background-color: #eff6ff; color: #1e40af; border-color: #bfdbfe; }
        .status-pending { background-color: #fefce8; color: #854d0e; border-color: #fef08a; }

        .indicator-dot {
            width: 10px;
            height: 10px;
            background-color: #3b82f6;
            border-radius: 50%;
            display: inline-block;
        }

        .table-form-input {
            font-size: 0.85rem !important;
            padding: 8px 24px 8px 12px !important;
            height: 40px;
            background-position: right 8px center !important;
            background-size: 12px !important;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
    </style>
</head>
<body>

    <div class="d-flex w-100 align-items-stretch">
        
        <div class="main-content">
            
            <div class="d-flex justify-content-between align-items-center header-container mb-4">
                <div>
                    <h4 class="fw-bold m-0">Purchase Order Management</h4>
                    <p class="text-muted small m-0 mt-1">Manage production variants hierarchy structures seamlessly.</p>
                </div>
                <button class="btn btn-custom-dark btn-sm px-3 py-2 fw-medium" type="button" id="toggleCollapseFormBtn">
                    <i class="fa-solid fa-plus me-1"></i> Create New Purchase Order
                </button>
            </div>

            <div class="collapse mb-4" id="newOrderCollapseForm">
                <div class="content-card border-primary">
                    <div class="card-title-bar bg-light text-secondary small d-flex justify-content-between align-items-center">
                        <span id="formPanelTitle">NEW PURCHASE ORDER DIALOG</span>
                    </div>
                    <div class="p-4">
                        <form id="purchaseOrderForm">
                            <input type="hidden" id="editingOrderId" value="">
                            
                            <div class="row g-3 mb-4">
                                <div class="col-sm-6 col-md-4">
                                    <label class="form-label small fw-semibold">Select Supplier</label>
                                    <select id="formSupplierSelect" class="form-select form-select-sm table-form-input">
                                        <option value="1">Al-Karam Textile Mills</option>
                                        <option value="2">Gul Ahmed Fabrics</option>
                                        <option value="3">Sana Safinaz Production Unit</option>
                                    </select>
                                </div>
                                <div class="col-sm-6 col-md-4">
                                    <label class="form-label small fw-semibold">Expected Delivery Date</label>
                                    <input type="date" id="formDeliveryDate" class="form-control form-control-sm table-form-input" value="2026-06-25">
                                </div>
                                <div class="col-sm-12 col-md-4">
                                    <label class="form-label small fw-semibold">Initial Order Status</label>
                                    <select id="formOrderStatus" class="form-select form-select-sm table-form-input">
                                        <option value="Pending Audit">Pending Audit</option>
                                        <option value="Approved">Approved</option>
                                    </select>
                                </div>
                            </div>

                            <div class="border-top pt-3">
                                <h6 class="fw-bold text-secondary small text-uppercase mb-3">Add Items to Order Manifest</h6>
                                
                                <div class="table-responsive shadow-sm border rounded">
                                    <table class="table table-bordered table-sm m-0 align-middle">
                                        <thead>
                                            <tr>
                                                <th class="col-w-subcat">Sub Category</th>
                                                <th class="col-w-prod">Product Name</th>
                                                <th class="col-w-sku">Variant SKU Lookups</th>
                                                <th class="col-w-qty">Qty</th>
                                                <th class="col-w-cost">Unit Cost (PKR)</th>
                                                <th class="col-w-subtotal">Computed Subtotal</th>
                                                <th style="width: 50px;" class="text-center">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody id="draftManifestItemsBody">
                                            <tr id="emptyRowPlaceholder">
                                                <td colspan="7" class="text-center text-muted py-4">No items added to this purchase draft yet. Click the button below to append rows.</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <div class="mt-3">
                                    <button type="button" id="appendVariantRowBtn" class="btn btn-outline-primary btn-sm fw-medium px-3 py-2">
                                        <i class="fa-solid fa-square-plus me-1"></i> Add Variant Item Row
                                    </button>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                                <button type="button" class="btn btn-sm btn-light border px-3" id="cancelFormBtn">Cancel</button>
                                <button type="button" id="savePurchaseOrderBtn" class="btn btn-sm btn-custom-dark px-4">Commit & Save Order</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-5 col-xl-5">
                    <div class="content-card">
                        <div class="card-title-bar">Active Suppliers</div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle m-0" id="supplierMasterTable">
                                <thead>
                                    <tr>
                                        <th>Supplier Details</th>
                                        <th>Category</th>
                                    </tr>
                                </thead>
                                <tbody id="supplierTableBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7 col-xl-7">
                    <div class="content-card">
                        <div class="card-title-bar d-flex align-items-center gap-2">
                            <div class="indicator-dot"></div>
                            <span>Associated Purchase Orders</span>
                        </div>
                        <div class="p-4" style="background-color: #f8fafc;">
                            <div class="mb-3">
                                <span class="text-uppercase text-secondary fw-bold" style="font-size: 0.65rem;">Active Records View</span>
                                <h5 class="fw-bold m-0 mt-1" id="selectedSupplierTitleDisplay">Al-Karam Textile Mills</h5>
                            </div>
                            <hr>
                            <div id="inspectorOrdersContainer"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
</body>
</html>
